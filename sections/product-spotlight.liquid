{% liquid
  assign colourway_blocks = section.blocks | where: 'type', 'colourway'
  assign first_block = colourway_blocks | first

  if first_block != blank
    assign first_product = first_block.settings.product
    assign initial_bg = first_block.settings.bg_color | default: '#111111'

    if first_block.settings.image != blank
      assign first_hero = first_block.settings.image | image_url: width: 1200
    elsif first_product != blank and first_product.featured_image != blank
      assign first_hero = first_product.featured_image | image_url: width: 1200
    endif

    if section.settings.title != blank
      assign display_title = section.settings.title
    elsif first_product != blank
      assign display_title = first_product.title
    endif
  endif
%}

<div
  class="ps-outer"
  id="ps-outer-{{ section.id }}"
  data-ps
  style="background-color: {{ initial_bg | default: '#111' }}; {% render 'spacing-style', settings: section.settings %}"
>
  <div class="ps-inner">

    <!-- ── Title spanning full width at top ── -->
    <div class="ps__header">
      <h2 class="ps__title" id="ps-title-{{ section.id }}">{{ display_title }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="ps__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="ps__layout">

      <!-- ── Left: hero image only ── -->
      <div class="ps__left">
        <div class="ps__hero-wrap">
          {%- if first_hero != blank -%}
            <img
              id="ps-hero-{{ section.id }}"
              class="ps__hero-img"
              src="{{ first_hero }}"
              alt="{{ display_title }}"
              loading="eager"
              width="1200"
              height="1200"
            >
          {%- else -%}
            <div class="ps__hero-fallback">
              {{ 'product-1' | placeholder_svg_tag: 'ps__hero-svg' }}
            </div>
          {%- endif -%}
        </div>
      </div>

      <!-- ── Right: soleplate → thumbs → sizes → buy ── -->
      <div class="ps__right">

        <!-- 1. Soleplate selector — built by JS from colourway data -->
        <div class="ps__soleplate-row" id="ps-soleplate-row-{{ section.id }}">
          <span class="ps__soleplate-label">Soleplate</span>
          <div class="ps__soleplate-btns" id="ps-soleplates-{{ section.id }}"></div>
        </div>

        <!-- 2. Colourway thumbnails (filtered by active soleplate) -->
        <div class="ps__thumbs" id="ps-thumbs-{{ section.id }}">
          {%- for block in colourway_blocks -%}
            {%- assign product = block.settings.product -%}

            {%- if block.settings.image != blank -%}
              {%- assign cw_hero  = block.settings.image | image_url: width: 1200 -%}
              {%- assign cw_thumb = block.settings.image | image_url: width: 200 -%}
            {%- elsif product != blank and product.featured_image != blank -%}
              {%- assign cw_hero  = product.featured_image | image_url: width: 1200 -%}
              {%- assign cw_thumb = product.featured_image | image_url: width: 200 -%}
            {%- else -%}
              {%- assign cw_hero  = '' -%}
              {%- assign cw_thumb = '' -%}
            {%- endif -%}

            {%- assign cw_name = block.settings.name -%}
            {%- if cw_name == blank and product != blank -%}
              {%- assign cw_name = product.title -%}
            {%- endif -%}

            {%- assign cw_soleplate = block.settings.soleplate | default: '' -%}

            <button
              class="ps__thumb{% if forloop.first %} ps__thumb--active{% endif %}"
              data-ps-thumb
              data-idx="{{ forloop.index0 }}"
              data-img="{{ cw_hero }}"
              data-bg="{{ block.settings.bg_color | default: initial_bg }}"
              data-name="{{ cw_name | escape }}"
              data-soleplate="{{ cw_soleplate | escape }}"
              aria-label="{{ cw_name | escape }}"
              aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}"
              {{ block.shopify_attributes }}
            >
              {%- if cw_thumb != blank -%}
                <img
                  src="{{ cw_thumb }}"
                  alt="{{ cw_name }}"
                  width="68"
                  height="68"
                  loading="lazy"
                  style="width:100%;height:100%;object-fit:cover;display:block;"
                >
              {%- else -%}
                <span class="ps__thumb-empty"></span>
              {%- endif -%}
            </button>

          {%- endfor -%}
        </div>

        <!-- 3. Size selector — populated by JS -->
        <div class="ps__size-row" id="ps-size-row-{{ section.id }}">
          <span class="ps__size-label">{{ section.settings.size_label | default: 'Size' }}</span>
          <div class="ps__size-grid" id="ps-sizes-{{ section.id }}"></div>
        </div>

        <!-- 4. Buy button -->
        <a
          id="ps-buy-{{ section.id }}"
          class="ps__buy-btn"
          href="{{ first_product.url | default: '#' }}"
        >
          {{- section.settings.buy_label | default: 'Buy Now' -}}
        </a>

      </div>
    </div>
  </div>

  <!-- ── Embedded variant data per colourway (read by JS) ── -->
  {%- for block in colourway_blocks -%}
    {%- assign product = block.settings.product -%}
    {%- if product == blank -%}{%- continue -%}{%- endif -%}

    {%- assign size_opt = 1 -%}
    {%- for opt in product.options -%}
      {%- assign opt_lower = opt | downcase -%}
      {%- if opt_lower contains 'size' -%}
        {%- assign size_opt = forloop.index -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}

    <script type="application/json" id="ps-data-{{ section.id }}-{{ forloop.index0 }}">
    {
      "productUrl": {{ product.url | json }},
      "variants": [
        {%- for variant in product.variants -%}
          {%- if size_opt == 1 -%}{%- assign sv = variant.option1 -%}
          {%- elsif size_opt == 2 -%}{%- assign sv = variant.option2 -%}
          {%- elsif size_opt == 3 -%}{%- assign sv = variant.option3 -%}
          {%- endif -%}
          {
            "id": {{ variant.id }},
            "size": {{ sv | json }},
            "available": {{ variant.available }},
            "url": {{ product.url | append: '?variant=' | append: variant.id | json }}
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    }
    </script>

  {%- endfor -%}

</div>

{% stylesheet %}
  /* ── Outer card shell ── */
  .ps-outer {
    margin-inline: 16px;
    margin-bottom: 32px;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 12px 48px rgba(0,0,0,0.28), 0 2px 10px rgba(0,0,0,0.14);
    transition: background-color 0.45s ease;
  }

  @media screen and (min-width: 750px) {
    .ps-outer { margin-inline: 40px; }
  }

  .ps-inner {
    padding-inline: 20px;
    padding-top: 24px;
  }

  @media screen and (min-width: 750px) {
    .ps-inner { padding-inline: 36px; padding-top: 32px; }
  }

  /* ── Full-width title header ── */
  .ps__header {
    padding-bottom: 20px;
  }

  .ps__title {
    font-size: clamp(1.4rem, 3vw, 2.2rem);
    font-weight: 800;
    color: #fff;
    margin: 0 0 4px;
    line-height: 1.15;
  }

  .ps__subtitle {
    font-size: 0.88rem;
    color: rgba(255,255,255,0.55);
    margin: 0;
    line-height: 1.5;
  }

  /* ── Two-column layout ── */
  .ps__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
  }

  @media screen and (max-width: 749px) {
    .ps__layout { grid-template-columns: 1fr; gap: 28px; }
  }

  /* Left — hero image only */
  .ps__left { display: flex; flex-direction: column; }

  .ps__hero-wrap {
    aspect-ratio: 1 / 1;
    border-radius: 14px;
    overflow: hidden;
    background: rgba(255,255,255,0.06);
  }

  .ps__hero-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    transition: opacity 0.25s ease;
  }

  .ps__hero-img.ps-fade { opacity: 0; }
  .ps__hero-fallback { width: 100%; height: 100%; opacity: 0.15; }
  .ps__hero-svg { width: 100%; height: 100%; }

  /* Right column */
  .ps__right {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding-top: 4px;
  }

  /* ── Soleplate selector ── */
  .ps__soleplate-row {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ps__soleplate-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.55);
  }

  .ps__soleplate-btns {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .ps__soleplate-btn {
    position: relative;
    width: 68px;
    height: 68px;
    border-radius: 50%;
    border: 2.5px solid transparent;
    overflow: hidden;
    cursor: pointer;
    padding: 0;
    background-color: rgba(255,255,255,0.08);
    background-size: cover;
    background-position: center;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s, transform 0.15s, box-shadow 0.2s;
  }

  .ps__soleplate-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.48);
    transition: background 0.2s;
  }

  .ps__soleplate-btn:hover { transform: scale(1.07); }
  .ps__soleplate-btn:hover::before { background: rgba(0,0,0,0.28); }

  .ps__soleplate-btn--active {
    border-color: #fff;
    box-shadow: 0 0 0 2px rgba(255,255,255,0.25);
  }

  .ps__soleplate-btn--active::before { background: rgba(0,0,0,0.22); }

  .ps__soleplate-btn__label {
    position: relative;
    z-index: 1;
    color: #fff;
    font-size: 0.68rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    text-align: center;
    line-height: 1;
    pointer-events: none;
    text-shadow: 0 1px 5px rgba(0,0,0,0.7);
  }

  /* ── Colourway thumbnails ── */
  .ps__thumbs { display: flex; flex-wrap: wrap; gap: 8px; }

  .ps__thumb {
    width: 68px;
    height: 68px;
    border-radius: 10px;
    border: 2px solid transparent;
    overflow: hidden;
    cursor: pointer;
    padding: 0;
    background: rgba(255,255,255,0.08);
    transition: border-color 0.2s, opacity 0.25s, transform 0.15s, box-shadow 0.2s;
    flex-shrink: 0;
  }

  .ps__thumb:hover { transform: scale(1.07); border-color: rgba(255,255,255,0.45); }
  .ps__thumb--active { border-color: #fff; box-shadow: 0 0 0 2px rgba(255,255,255,0.25); }
  .ps__thumb--unavailable { opacity: 0.2; pointer-events: none; transform: none; }
  .ps__thumb--hidden { display: none; }
  .ps__thumb-empty { display: block; width: 100%; height: 100%; background: rgba(255,255,255,0.15); }

  /* ── Size selector ── */
  .ps__size-row { display: flex; flex-direction: column; gap: 10px; }

  .ps__size-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.55);
  }

  .ps__size-grid { display: flex; flex-wrap: wrap; gap: 7px; min-height: 36px; }

  .ps__size-btn {
    padding: 7px 13px;
    border-radius: 8px;
    border: 1.5px solid rgba(255,255,255,0.25);
    background: transparent;
    color: rgba(255,255,255,0.8);
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s, opacity 0.2s;
    line-height: 1;
  }

  .ps__size-btn:hover {
    background: rgba(255,255,255,0.12);
    border-color: rgba(255,255,255,0.65);
    color: #fff;
  }

  .ps__size-btn--active { background: #fff; color: #111; border-color: #fff; }
  .ps__size-btn--sold-out { opacity: 0.3; text-decoration: line-through; cursor: not-allowed; }

  /* ── Buy button ── */
  .ps__buy-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 17px 24px;
    background: #fff;
    color: #111;
    font-size: 1rem;
    font-weight: 800;
    border-radius: 12px;
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: background 0.15s, transform 0.15s;
    text-align: center;
  }

  .ps__buy-btn:hover { background: rgba(255,255,255,0.88); transform: translateY(-1px); }
{% endstylesheet %}

<script>
  (function () {
    var sid      = {{ section.id | json }};
    var wrap     = document.getElementById('ps-outer-' + sid);
    if (!wrap) return;

    var heroImg       = document.getElementById('ps-hero-' + sid);
    var buyBtn        = document.getElementById('ps-buy-' + sid);
    var sizeGrid      = document.getElementById('ps-sizes-' + sid);
    var spContainer   = document.getElementById('ps-soleplates-' + sid);
    var spRow         = document.getElementById('ps-soleplate-row-' + sid);
    var thumbs        = Array.from(wrap.querySelectorAll('[data-ps-thumb]'));

    var activeIdx       = 0;
    var activeSize      = null;
    var activeSoleplate = null;
    var cache           = {};

    /* ── load + cache product data ── */
    function getData(idx) {
      if (cache[idx]) return cache[idx];
      var el = document.getElementById('ps-data-' + sid + '-' + idx);
      if (!el) return null;
      try { cache[idx] = JSON.parse(el.textContent); } catch (e) { return null; }
      return cache[idx];
    }

    /* ── visible thumbs (not hidden by soleplate filter) ── */
    function visibleThumbs() {
      return thumbs.filter(function (t) {
        return !t.classList.contains('ps__thumb--hidden');
      });
    }

    /* ── unique soleplates in declaration order ── */
    function uniqueSoleplates() {
      var seen = [];
      thumbs.forEach(function (t) {
        var sp = t.dataset.soleplate;
        if (sp && seen.indexOf(sp) === -1) seen.push(sp);
      });
      return seen;
    }

    /* ── render soleplate circle buttons ── */
    function renderSoleplates() {
      var sps = uniqueSoleplates();
      if (!sps.length) {
        if (spRow) spRow.style.display = 'none';
        return;
      }
      sps.forEach(function (sp, i) {
        /* use the hero image of the first colourway in this soleplate group */
        var matchThumb = thumbs.find(function (t) { return t.dataset.soleplate === sp; });
        var bgImg = matchThumb ? matchThumb.dataset.img : '';

        var btn = document.createElement('button');
        btn.className = 'ps__soleplate-btn' + (i === 0 ? ' ps__soleplate-btn--active' : '');
        btn.dataset.soleplate = sp;
        if (bgImg) btn.style.backgroundImage = 'url(' + bgImg + ')';

        var label = document.createElement('span');
        label.className = 'ps__soleplate-btn__label';
        label.textContent = sp;
        btn.appendChild(label);

        btn.addEventListener('click', function () { selectSoleplate(btn); });
        spContainer.appendChild(btn);
      });
      filterBySoleplate(sps[0]);
    }

    /* ── filter colourway thumbs to those matching soleplate ── */
    function filterBySoleplate(sp) {
      activeSoleplate = sp;
      /* reset size when soleplate changes */
      activeSize = null;
      Array.from(sizeGrid.querySelectorAll('.ps__size-btn')).forEach(function (b) {
        b.classList.remove('ps__size-btn--active');
      });

      thumbs.forEach(function (t) {
        var match = !sp || t.dataset.soleplate === sp;
        t.classList.toggle('ps__thumb--hidden', !match);
        t.classList.remove('ps__thumb--unavailable');
      });

      /* if currently active thumb got hidden, jump to first visible */
      if (thumbs[activeIdx] && thumbs[activeIdx].classList.contains('ps__thumb--hidden')) {
        var first = visibleThumbs()[0];
        if (first) selectColourway(first, true);
      }

      renderAllSizes();
      updateBuyUrl();
    }

    /* ── select a soleplate pill ── */
    function selectSoleplate(btn) {
      Array.from(spContainer.querySelectorAll('.ps__soleplate-btn')).forEach(function (b) {
        b.classList.remove('ps__soleplate-btn--active');
      });
      btn.classList.add('ps__soleplate-btn--active');
      filterBySoleplate(btn.dataset.soleplate);
    }

    /* ── unique sizes across visible colourways only, sorted A-Z ── */
    function allUniqueSizes() {
      var seen = [];
      visibleThumbs().forEach(function (t) {
        var i = parseInt(t.dataset.idx);
        var d = getData(i);
        if (!d) return;
        d.variants.forEach(function (v) {
          if (v.size && seen.indexOf(v.size) === -1) seen.push(v.size);
        });
      });
      seen.sort(function (a, b) {
        return a.localeCompare(b, undefined, { numeric: true, sensitivity: 'base' });
      });
      return seen;
    }

    /* ── render size buttons (called on init and after soleplate change) ── */
    function renderAllSizes() {
      sizeGrid.innerHTML = '';
      allUniqueSizes().forEach(function (size) {
        var btn = document.createElement('button');
        btn.className = 'ps__size-btn';
        btn.textContent = size;
        btn.dataset.size = size;
        btn.addEventListener('click', function () { selectSize(btn); });
        sizeGrid.appendChild(btn);
      });
    }

    /* ── select a size ── */
    function selectSize(btn) {
      var size = btn.dataset.size;

      /* toggle off */
      if (btn.classList.contains('ps__size-btn--active')) {
        btn.classList.remove('ps__size-btn--active');
        activeSize = null;
        visibleThumbs().forEach(function (t) { t.classList.remove('ps__thumb--unavailable'); });
        updateBuyUrl();
        return;
      }

      Array.from(sizeGrid.querySelectorAll('.ps__size-btn')).forEach(function (b) {
        b.classList.remove('ps__size-btn--active');
      });
      btn.classList.add('ps__size-btn--active');
      activeSize = size;

      var firstAvail = null;
      visibleThumbs().forEach(function (t) {
        var i = parseInt(t.dataset.idx);
        var d = getData(i);
        var hasStock = d && d.variants.some(function (v) {
          return v.size === size && v.available;
        });
        t.classList.toggle('ps__thumb--unavailable', !hasStock);
        if (hasStock && firstAvail === null) firstAvail = t;
      });

      if (thumbs[activeIdx] && thumbs[activeIdx].classList.contains('ps__thumb--unavailable')) {
        if (firstAvail) selectColourway(firstAvail, true);
      } else {
        updateBuyUrl();
      }
    }

    /* ── update buy URL for active colourway + selected size ── */
    function updateBuyUrl() {
      if (!buyBtn) return;
      var d = getData(activeIdx);
      if (!d) return;
      if (activeSize) {
        var match = d.variants.find(function (v) {
          return v.size === activeSize && v.available;
        });
        buyBtn.href = match ? match.url : d.productUrl;
      } else {
        buyBtn.href = d.productUrl;
      }
    }

    /* ── select a colourway thumb ── */
    function selectColourway(thumb, skipSizeReset) {
      var idx    = parseInt(thumb.dataset.idx);
      var newImg = thumb.dataset.img;
      var newBg  = thumb.dataset.bg;

      thumbs.forEach(function (t) {
        t.classList.remove('ps__thumb--active');
        t.setAttribute('aria-pressed', 'false');
      });
      thumb.classList.add('ps__thumb--active');
      thumb.setAttribute('aria-pressed', 'true');
      activeIdx = idx;

      if (heroImg && newImg) {
        heroImg.classList.add('ps-fade');
        setTimeout(function () {
          heroImg.src = newImg;
          heroImg.onload = function () { heroImg.classList.remove('ps-fade'); };
          if (heroImg.complete) heroImg.classList.remove('ps-fade');
        }, 130);
      }

      if (newBg) wrap.style.backgroundColor = newBg;

      updateBuyUrl();
    }

    /* ── wire thumb clicks ── */
    thumbs.forEach(function (t) {
      t.addEventListener('click', function () { selectColourway(t); });
    });

    /* ── init ── */
    renderSoleplates();   /* also calls renderAllSizes + filterBySoleplate */
    updateBuyUrl();

    /* preload hero images */
    thumbs.forEach(function (t) {
      if (t.dataset.img) { var i = new Image(); i.src = t.dataset.img; }
    });
  })();
</script>

{% schema %}
{
  "name": "Product Spotlight",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Product"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title override",
      "info": "Leave blank to use the first linked product's title"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle / tagline"
    },
    {
      "type": "header",
      "content": "Labels"
    },
    {
      "type": "text",
      "id": "size_label",
      "label": "Size label",
      "default": "Size"
    },
    {
      "type": "text",
      "id": "buy_label",
      "label": "Buy button text",
      "default": "Buy Now"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0, "max": 120, "step": 4, "unit": "px", "default": 60
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0, "max": 120, "step": 4, "unit": "px", "default": 60
    }
  ],
  "blocks": [
    {
      "type": "colourway",
      "name": "Colourway",
      "settings": [
        {
          "type": "text",
          "id": "soleplate",
          "label": "Soleplate",
          "info": "e.g. FG, AG, SG, TF — colourways with the same soleplate are grouped together"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product",
          "info": "Sizes and buy URL are pulled automatically from this product's variants"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Background colour",
          "default": "#111111"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom hero image",
          "info": "Overrides the product's featured image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Custom colourway name",
          "info": "Overrides the product title in labels"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Spotlight",
      "blocks": [
        { "type": "colourway" },
        { "type": "colourway" },
        { "type": "colourway" }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
