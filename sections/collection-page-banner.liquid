{%- liquid
  assign use_img       = collection.image | default: section.settings.image
  assign overlay_alpha = section.settings.overlay_opacity | times: 0.01
  assign height        = section.settings.height | default: 380
  assign heading       = section.settings.heading
  assign subtext       = section.settings.subtext
  assign show_title    = section.settings.show_title
-%}

<div class="cpb-outer">
<div
  class="cpb-section"
  style="--cpb-height: {{ height }}px;"
>
  <div class="cpb-media">
    {%- if use_img != blank -%}
      <img
        class="cpb-img"
        src="{{ use_img | image_url: width: 2000 }}"
        srcset="
          {{ use_img | image_url: width: 900  }} 900w,
          {{ use_img | image_url: width: 1400 }} 1400w,
          {{ use_img | image_url: width: 2000 }} 2000w
        "
        sizes="100vw"
        alt="{{ collection.title | escape }}"
        loading="eager"
        fetchpriority="high"
        width="2000"
        height="800"
      >
    {%- else -%}
      <div class="cpb-placeholder"></div>
    {%- endif -%}
    <div class="cpb-overlay" style="background: rgba(0,0,0,{{ overlay_alpha | round: 2 }});"></div>
  </div>

  {%- if show_title or heading != blank or subtext != blank -%}
    <div class="cpb-content">
      {%- if heading != blank -%}
        <h1 class="cpb-title">{{ heading }}</h1>
      {%- elsif show_title -%}
        <h1 class="cpb-title">{{ collection.title }}</h1>
      {%- endif -%}
      {%- if subtext != blank -%}
        <p class="cpb-desc">{{ subtext }}</p>
      {%- elsif collection.description != blank and show_title -%}
        <p class="cpb-desc">{{ collection.description | strip_html | truncate: 180 }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>
</div>

{% stylesheet %}
  .cpb-outer {
    padding: 16px 16px 0;
  }

  .cpb-section {
    position: relative;
    height: var(--cpb-height, 380px);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 16px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.28), 0 2px 8px rgba(0, 0, 0, 0.16);
  }

  @media screen and (max-width: 749px) {
    .cpb-outer {
      padding: 10px 10px 0;
    }
    .cpb-section {
      height: calc(var(--cpb-height, 380px) / 2);
      border-radius: 12px;
    }
  }

  .cpb-media {
    position: absolute;
    inset: 0;
  }

  .cpb-img,
  .cpb-placeholder {
    width: 100%;
    height: 100%;
    display: block;
  }

  .cpb-img { object-fit: cover; }
  .cpb-placeholder { background: #1a1a1a; }

  .cpb-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .cpb-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding-inline: 24px;
    max-width: 760px;
  }

  .cpb-title {
    color: #fff;
    font-size: clamp(1.8rem, 5vw, 3.8rem);
    font-weight: 800;
    margin: 0 0 10px;
    line-height: 1.1;
    letter-spacing: -0.02em;
    text-shadow: 0 2px 12px rgba(0,0,0,0.35);
  }

  .cpb-desc {
    color: rgba(255,255,255,0.75);
    font-size: clamp(0.85rem, 2vw, 1rem);
    margin: 0;
    line-height: 1.55;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection Banner",
  "tag": "section",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Fallback banner image",
      "info": "Used only when a collection has no image set. Set each collection's image via Shopify admin → Collections → [Collection] → Collection image."
    },
    {
      "type": "range",
      "id": "height",
      "label": "Banner height (desktop)",
      "min": 160,
      "max": 700,
      "step": 10,
      "unit": "px",
      "default": 380
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay darkness",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 35
    },
    {
      "type": "header",
      "content": "Text overlay"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Leave blank to use the collection title instead"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "info": "Leave blank to use the collection description instead"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show collection title / description when no custom text is set",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Collection Banner"
    }
  ]
}
{% endschema %}
