{%- liquid
  assign heading    = section.settings.heading
  assign subheading = section.settings.subheading

  assign ratio_str  = section.settings.card_aspect_ratio | default: '3/4'
  assign rparts     = ratio_str | split: '/'
  assign r_w        = rparts[0] | times: 1.0
  assign r_h        = rparts[1] | times: 1.0
  assign r_mult     = r_h | divided_by: r_w
-%}

<div
  class="cc-section"
  id="cc-{{ section.id }}"
  style="{% render 'spacing-style', settings: section.settings %}"
>

  {%- if heading != blank or subheading != blank -%}
    <div class="cc-header">
      <div>
        {%- if heading != blank -%}
          <h2 class="cc-header__title">{{ heading }}</h2>
        {%- endif -%}
        {%- if subheading != blank -%}
          <p class="cc-header__sub">{{ subheading }}</p>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  <div
    class="cc-stage"
    id="cc-stage-{{ section.id }}"
    style="--cc-ratio: {{ r_mult | round: 4 }};"
  >
    <!-- Sentinel drives stage height without JS -->
    <div class="cc-sentinel" aria-hidden="true"></div>

    <!-- Cards -->
    {%- assign blocks = section.blocks -%}
    {%- if blocks.size == 0 -%}
      {%- assign placeholder = true -%}
    {%- endif -%}

    {%- if placeholder -%}
      {%- for i in (1..5) -%}
        <div class="cc-card{% if forloop.index0 == 1 %} cc-card--active{% endif %}" data-cc-idx="{{ forloop.index0 }}">
          <div class="cc-card__inner">
            <div class="cc-card__media">
              <div class="cc-card__placeholder">
                {{ 'collection-1' | placeholder_svg_tag: 'cc-placeholder-svg' }}
              </div>
              <div class="cc-card__overlay"></div>
            </div>
            <div class="cc-card__body">
              <span class="cc-card__title">Collection {{ i }}</span>
              <span class="cc-card__cta">Shop Now</span>
            </div>
          </div>
        </div>
      {%- endfor -%}
    {%- else -%}
      {%- for block in blocks -%}
        {%- assign img   = block.settings.image -%}
        {%- assign title = block.settings.title -%}
        {%- assign sub   = block.settings.subtitle -%}
        {%- assign link  = block.settings.link -%}
        {%- assign cta   = block.settings.cta_label -%}

        <div
          class="cc-card{% if forloop.index0 == 1 %} cc-card--active{% endif %}"
          data-cc-idx="{{ forloop.index0 }}"
          {{ block.shopify_attributes }}
        >
          {%- if link != blank -%}
            <a href="{{ link }}" class="cc-card__inner" aria-label="{{ title | escape }}">
          {%- else -%}
            <div class="cc-card__inner">
          {%- endif -%}

            <div class="cc-card__media">
              {%- if img != blank -%}
                <img
                  class="cc-card__img"
                  src="{{ img | image_url: width: 800 }}"
                  srcset="
                    {{ img | image_url: width: 400 }} 400w,
                    {{ img | image_url: width: 800 }} 800w,
                    {{ img | image_url: width: 1200 }} 1200w
                  "
                  sizes="(max-width: 749px) 75vw, 30vw"
                  alt="{{ title | escape }}"
                  loading="lazy"
                  width="800"
                  height="1067"
                >
              {%- else -%}
                <div class="cc-card__placeholder">
                  {{ 'collection-1' | placeholder_svg_tag: 'cc-placeholder-svg' }}
                </div>
              {%- endif -%}
              <div class="cc-card__overlay"></div>
            </div>

            {%- if title != blank or sub != blank or cta != blank -%}
              <div class="cc-card__body">
                {%- if title != blank -%}
                  <span class="cc-card__title">{{ title }}</span>
                {%- endif -%}
                {%- if sub != blank -%}
                  <span class="cc-card__sub">{{ sub }}</span>
                {%- endif -%}
                {%- if cta != blank -%}
                  <span class="cc-card__cta">{{ cta }}</span>
                {%- endif -%}
              </div>
            {%- endif -%}

          {%- if link != blank -%}
            </a>
          {%- else -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    {%- endif -%}

    <!-- Navigation arrows -->
    <button class="cc-nav cc-nav--prev" id="cc-prev-{{ section.id }}" aria-label="Previous">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <button class="cc-nav cc-nav--next" id="cc-next-{{ section.id }}" aria-label="Next">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
  </div>

</div>

{% stylesheet %}
  .cc-section {
    padding-block: 48px;
    overflow: hidden;
  }

  /* ── Header ── */
  .cc-header {
    padding-inline: 24px;
    margin-bottom: 28px;
    text-align: center;
  }

  .cc-header__title {
    font-size: clamp(1.5rem, 4vw, 2.4rem);
    font-weight: 800;
    margin: 0 0 6px;
    line-height: 1.1;
  }

  .cc-header__sub {
    font-size: 0.92rem;
    opacity: 0.55;
    margin: 0;
  }

  /* ── Stage (perspective container) ── */
  .cc-stage {
    position: relative;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    perspective: 1200px;
    /* extra vertical room so scaled-up center card doesn't clip */
    padding-block: 24px;
    touch-action: pan-y;
    user-select: none;
    -webkit-user-select: none;
  }

  /* Invisible sentinel sets intrinsic stage height via card dimensions */
  .cc-sentinel {
    --cc-card-w: clamp(220px, 70vw, 290px);
    width: var(--cc-card-w);
    aspect-ratio: calc(1 / var(--cc-ratio, 1.333));
    visibility: hidden;
    pointer-events: none;
    flex-shrink: 0;
  }

  @media screen and (min-width: 750px) {
    .cc-sentinel { --cc-card-w: clamp(260px, 26vw, 340px); }
  }

  /* ── Cards ── */
  .cc-card {
    --cc-card-w: clamp(220px, 70vw, 290px);
    position: absolute;
    top: 50%;
    left: 50%;
    width: var(--cc-card-w);
    border-radius: 18px;
    overflow: hidden;
    cursor: pointer;
    /* transform set entirely by JS; base is just the centering */
    transform: translate(-50%, -50%);
    transition:
      transform 0.52s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      opacity   0.52s ease,
      box-shadow 0.52s ease;
    will-change: transform, opacity;
  }

  @media screen and (min-width: 750px) {
    .cc-card { --cc-card-w: clamp(260px, 26vw, 340px); border-radius: 22px; }
  }

  .cc-card--active { cursor: default; }

  .cc-card__inner {
    display: block;
    text-decoration: none;
    color: inherit;
    position: relative;
    line-height: 0;
  }

  .cc-card__media {
    position: relative;
    aspect-ratio: calc(1 / var(--cc-ratio, 1.333));
    overflow: hidden;
    background: #1a1a1a;
  }

  .cc-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    line-height: 0;
    transition: transform 0.5s ease;
  }

  .cc-card--active .cc-card__img { transform: scale(1.03); }

  .cc-card__placeholder {
    width: 100%;
    height: 100%;
    background: #e0e0e0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cc-placeholder-svg { width: 55%; height: 55%; opacity: 0.2; }

  /* Gradient overlay */
  .cc-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.82) 0%,
      rgba(0,0,0,0.28) 45%,
      rgba(0,0,0,0) 70%
    );
    pointer-events: none;
  }

  /* Text body pinned to bottom */
  .cc-card__body {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 24px 18px 18px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    line-height: normal;
  }

  .cc-card__title {
    display: block;
    color: #fff;
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .cc-card__sub {
    display: block;
    color: rgba(255,255,255,0.7);
    font-size: 0.78rem;
    line-height: 1.4;
  }

  .cc-card__cta {
    display: inline-block;
    margin-top: 10px;
    padding: 8px 20px;
    background: #fff;
    color: #111;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border-radius: 999px;
    width: fit-content;
    line-height: normal;
  }

  /* ── Navigation arrows ── */
  .cc-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 20;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    border: none;
    background: #fff;
    color: #111;
    box-shadow: 0 4px 18px rgba(0,0,0,0.18);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.15s, box-shadow 0.15s, background 0.15s;
  }

  .cc-nav svg { width: 20px; height: 20px; pointer-events: none; }

  .cc-nav--prev { left: 14px; }
  .cc-nav--next { right: 14px; }

  @media screen and (min-width: 750px) {
    .cc-nav--prev { left: 32px; }
    .cc-nav--next { right: 32px; }
  }

  .cc-nav:hover {
    background: #f0f0f0;
    box-shadow: 0 6px 24px rgba(0,0,0,0.22);
    transform: translateY(-50%) scale(1.08);
  }

  .cc-nav:disabled {
    opacity: 0.35;
    cursor: default;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }

  .cc-nav:disabled:hover { transform: translateY(-50%); background: #fff; }
{% endstylesheet %}

<script>
(function () {
  var sid   = {{ section.id | json }};
  var stage = document.getElementById('cc-stage-' + sid);
  if (!stage) return;

  var cards = Array.from(stage.querySelectorAll('.cc-card'));
  var prev  = document.getElementById('cc-prev-' + sid);
  var next  = document.getElementById('cc-next-' + sid);
  var active = 1;
  var total  = cards.length;

  /* ── Step lookup tables (index = abs integer offset) ── */
  var TX_RATIO = [0, 0.80, 1.42, 1.90];
  var TZ       = [0, -50,  -90, -130];
  var RY       = [0,   8,   15,   20];
  var SCALE    = [1, 0.84, 0.70, 0.58];
  var OPACITY  = [1, 0.88, 0.72, 0.58];

  function cardW() { return cards[0] ? cards[0].offsetWidth : 280; }

  /* Linearly interpolate a step table at a fractional abs-offset */
  function lookup(arr, absOff) {
    var lo = Math.min(Math.floor(absOff), arr.length - 2);
    var t  = absOff - lo;
    return arr[lo] + (arr[lo + 1] - arr[lo]) * Math.min(t, 1);
  }

  /* Apply transforms for any (possibly fractional) center position */
  function render(center) {
    var w = cardW();
    cards.forEach(function (card, i) {
      var off    = i - center;
      var absOff = Math.abs(off);
      var sign   = off >= 0 ? 1 : -1;

      var tx    = sign * lookup(TX_RATIO, absOff) * w;
      var tz    = lookup(TZ,      absOff);
      var ry    = -sign * lookup(RY,    absOff);
      var sc    = lookup(SCALE,   absOff);
      var op    = lookup(OPACITY, absOff);

      card.style.transform =
        'translate(-50%,-50%) ' +
        'translateX('  + tx.toFixed(1) + 'px) ' +
        'translateZ('  + tz.toFixed(1) + 'px) ' +
        'rotateY('     + ry.toFixed(2) + 'deg) ' +
        'scale('       + sc.toFixed(4) + ')';

      card.style.opacity  = op.toFixed(3);
      card.style.zIndex   = Math.round(20 - absOff * 4);
      card.style.boxShadow = absOff < 0.5
        ? '0 24px 60px rgba(0,0,0,0.36), 0 6px 16px rgba(0,0,0,0.2)'
        : 'none';
      card.classList.toggle('cc-card--active', i === Math.round(center));
    });
    if (prev) prev.disabled = active <= 0;
    if (next) next.disabled = active >= total - 1;
  }

  function setTransition(on) {
    var t = on
      ? 'transform 0.48s cubic-bezier(0.25,0.46,0.45,0.94), opacity 0.48s ease, box-shadow 0.48s ease'
      : 'none';
    cards.forEach(function (c) { c.style.transition = t; });
  }

  function goTo(idx) {
    active = Math.max(0, Math.min(total - 1, idx));
    setTransition(true);
    render(active);
  }

  /* ── Side-card tap ── */
  var wasDragged = false;
  cards.forEach(function (card, i) {
    card.addEventListener('click', function (e) {
      if (wasDragged) { e.preventDefault(); return; }
      if (i === active) return;
      e.preventDefault();
      goTo(i);
    });
  });

  /* ── Arrows ── */
  if (prev) prev.addEventListener('click', function () { goTo(active - 1); });
  if (next) next.addEventListener('click', function () { goTo(active + 1); });

  /* ── Fluid drag / swipe ── */
  var dragging   = false;
  var dragId     = -1;
  var startX     = 0;
  var startT     = 0;
  var liveCenter = active;

  stage.addEventListener('pointerdown', function (e) {
    /* Ignore non-primary mouse buttons and button/link targets
       so arrow clicks and card links are never swallowed */
    if (e.button !== 0 && e.pointerType === 'mouse') return;
    if (e.target.closest('button, a')) return;

    dragging   = true;
    wasDragged = false;
    dragId     = e.pointerId;
    startX     = e.clientX;
    startT     = Date.now();
    liveCenter = active;
    setTransition(false);
  }, { passive: true });

  /* Listen on window so drag stays tracked if pointer leaves the stage */
  window.addEventListener('pointermove', function (e) {
    if (!dragging || e.pointerId !== dragId) return;
    var dx = e.clientX - startX;
    if (Math.abs(dx) > 8) wasDragged = true;
    if (!wasDragged) return;

    var raw = active - dx / cardW();
    if (raw < 0) {
      raw = -Math.pow(-raw, 0.55);
    } else if (raw > total - 1) {
      raw = (total - 1) + Math.pow(raw - (total - 1), 0.55);
    }
    liveCenter = raw;
    render(liveCenter);
  }, { passive: true });

  function onRelease(e) {
    if (!dragging || e.pointerId !== dragId) return;
    dragging = false;

    /* Pure click (no real drag) — just restore and let click handlers run */
    if (!wasDragged) {
      setTransition(true);
      render(active);
      return;
    }

    var dx       = e.clientX - startX;
    var velocity = dx / Math.max(Date.now() - startT, 1); /* px/ms */
    goTo(Math.abs(velocity) > 0.28
      ? active + (velocity < 0 ? 1 : -1)
      : Math.round(liveCenter));
  }

  window.addEventListener('pointerup',     onRelease, { passive: true });
  window.addEventListener('pointercancel', onRelease, { passive: true });

  /* ── Init (instant placement, then enable transitions) ── */
  setTransition(false);
  render(active);
  requestAnimationFrame(function () { setTransition(true); });

  window.addEventListener('resize', function () { render(active); }, { passive: true });
})();
</script>

{% schema %}
{
  "name": "Collection Carousel",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Title",
      "default": "Shop by Collection"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "header",
      "content": "Cards"
    },
    {
      "type": "select",
      "id": "card_aspect_ratio",
      "label": "Card aspect ratio",
      "options": [
        { "value": "1/1",  "label": "Square (1:1)" },
        { "value": "3/4",  "label": "Portrait (3:4)" },
        { "value": "2/3",  "label": "Tall portrait (2:3)" },
        { "value": "4/3",  "label": "Landscape (4:3)" }
      ],
      "default": "3/4"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0, "max": 120, "step": 4, "unit": "px", "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0, "max": 120, "step": 4, "unit": "px", "default": 48
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Collection Name"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "Button label",
          "default": "Shop Now"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Carousel",
      "blocks": [
        { "type": "card" },
        { "type": "card" },
        { "type": "card" },
        { "type": "card" },
        { "type": "card" }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
