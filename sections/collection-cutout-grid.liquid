{%- liquid
  assign heading    = section.settings.heading
  assign subheading = section.settings.subheading
  assign ratio      = section.settings.image_ratio | default: '1/1'
  assign cols_d     = section.settings.columns_desktop | plus: 0
  assign cols_m     = section.settings.columns_mobile | plus: 0
  assign img_span   = 92 | divided_by: cols_d

  # Tighter gaps as column counts rise so dense grids don't starve the cards
  if cols_d >= 7
    assign gap_d = '20px 14px'
  elsif cols_d >= 5
    assign gap_d = '32px 22px'
  else
    assign gap_d = '44px 32px'
  endif
  if cols_m >= 3
    assign gap_m = '18px 10px'
  else
    assign gap_m = '28px 20px'
  endif
-%}

<div
  class="ccg-section"
  style="{% render 'spacing-style', settings: section.settings %}"
>

  {%- if heading != blank or subheading != blank -%}
    <div class="ccg-header">
      {%- if heading != blank -%}
        <h2 class="ccg-header__title">{{ heading }}</h2>
      {%- endif -%}
      {%- if subheading != blank -%}
        <p class="ccg-header__sub">{{ subheading }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%}
    SVG filter: dilates the PNG alpha into a paper border, roughens the
    edge with fractal-noise displacement (the hand-cut look), and tints
    it a warm paper tone. Scoped by section id to allow multiple copies.
  {%- endcomment -%}
  <svg width="0" height="0" style="position:absolute" aria-hidden="true" focusable="false">
    <filter id="ccg-edge-{{ section.id }}" x="-25%" y="-25%" width="150%" height="150%" color-interpolation-filters="sRGB">
      <feMorphology in="SourceAlpha" operator="dilate" radius="4" result="border"/>
      <feTurbulence type="fractalNoise" baseFrequency="0.05" numOctaves="2" seed="11" result="noise"/>
      <feDisplacementMap in="border" in2="noise" scale="2.5" xChannelSelector="R" yChannelSelector="G" result="rough"/>
      <feFlood flood-color="#fbfaf6" result="paper"/>
      <feComposite in="paper" in2="rough" operator="in" result="paper-edge"/>
      <feMerge>
        <feMergeNode in="paper-edge"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </svg>

  <div
    class="ccg-grid"
    style="--ccg-ratio: {{ ratio }}; --ccg-cols: {{ cols_d }}; --ccg-cols-m: {{ cols_m }}; --ccg-gap: {{ gap_d }}; --ccg-gap-m: {{ gap_m }}; --ccg-filter: url('#ccg-edge-{{ section.id }}');"
  >
    {%- if section.blocks.size == 0 -%}
      {%- for i in (1..4) -%}
        <div class="ccg-item">
          <div class="ccg-cutout">
            <div class="ccg-media">
              {{ 'collection-1' | placeholder_svg_tag: 'ccg-placeholder-svg' }}
            </div>
          </div>
          <span class="ccg-caption">Collection {{ i }}</span>
        </div>
      {%- endfor -%}
    {%- else -%}
      {%- for block in section.blocks -%}
        {%- liquid
          assign col   = block.settings.collection
          assign img   = block.settings.image | default: col.image
          assign title = block.settings.title | default: col.title
          assign link  = block.settings.link | default: col.url
        -%}

        <div class="ccg-item" {{ block.shopify_attributes }}>
          {%- if link != blank -%}
            <a href="{{ link }}" class="ccg-link" aria-label="{{ title | escape }}">
          {%- else -%}
            <div class="ccg-link">
          {%- endif -%}

            <div class="ccg-cutout">
              <div class="ccg-media">
                {%- if img != blank -%}
                  <img
                    class="ccg-img"
                    src="{{ img | image_url: width: 600 }}"
                    srcset="
                      {{ img | image_url: width: 300 }} 300w,
                      {{ img | image_url: width: 600 }} 600w,
                      {{ img | image_url: width: 900 }} 900w
                    "
                    sizes="(max-width: 749px) {{ 92 | divided_by: cols_m }}vw, {{ img_span }}vw"
                    alt="{{ title | escape }}"
                    loading="lazy"
                    decoding="async"
                    width="600"
                    height="800"
                  >
                {%- else -%}
                  {{ 'collection-1' | placeholder_svg_tag: 'ccg-placeholder-svg' }}
                {%- endif -%}
              </div>
            </div>
            {%- if title != blank -%}
              <span class="ccg-caption">{{ title }}</span>
            {%- endif -%}

          {%- if link != blank -%}
            </a>
          {%- else -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>

</div>

{% stylesheet %}
  .ccg-section {
    padding-block: 48px;
    overflow: hidden; /* tilted cutouts can poke past the edge */
  }

  .ccg-header {
    padding-inline: 24px;
    margin-bottom: 32px;
    text-align: center;
  }

  .ccg-header__title {
    font-size: clamp(1.5rem, 4vw, 2.4rem);
    font-weight: 800;
    margin: 0 0 6px;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .ccg-header__sub {
    font-size: 0.92rem;
    opacity: 0.55;
    margin: 0;
  }

  /* ── Grid ── */
  .ccg-grid {
    display: grid;
    grid-template-columns: repeat(var(--ccg-cols-m, 2), 1fr);
    gap: var(--ccg-gap-m, 28px 20px);
    padding-inline: 20px;
    max-width: 1200px;
    margin-inline: auto;
  }

  @media screen and (min-width: 750px) {
    .ccg-grid {
      grid-template-columns: repeat(var(--ccg-cols, 4), 1fr);
      gap: var(--ccg-gap, 44px 32px);
      padding-inline: 40px;
    }
  }

  .ccg-item { min-width: 0; }

  .ccg-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    text-decoration: none;
    color: inherit;
    -webkit-tap-highlight-color: transparent;
  }

  /* ── Paper cutout — die-cut sticker hugging the product silhouette.
        Images are transparent-background PNGs; the white "paper" edge
        and the page shadow both follow the alpha channel. ── */
  .ccg-cutout {
    width: 100%;
    transform: rotate(var(--ccg-tilt, 0deg));
    transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
    will-change: transform;
  }

  /* Every cutout lands on the page at its own angle */
  .ccg-item:nth-child(6n + 1) .ccg-cutout { --ccg-tilt: -2.2deg; }
  .ccg-item:nth-child(6n + 2) .ccg-cutout { --ccg-tilt:  1.7deg; }
  .ccg-item:nth-child(6n + 3) .ccg-cutout { --ccg-tilt: -1.2deg; }
  .ccg-item:nth-child(6n + 4) .ccg-cutout { --ccg-tilt:  2.3deg; }
  .ccg-item:nth-child(6n + 5) .ccg-cutout { --ccg-tilt: -1.7deg; }
  .ccg-item:nth-child(6n + 6) .ccg-cutout { --ccg-tilt:  1.2deg; }

  /* Hover: the cutout straightens and lifts off the page */
  @media (hover: hover) {
    .ccg-link:hover .ccg-cutout {
      transform: rotate(0deg) translateY(-8px) scale(1.04);
    }
  }

  /* Touch: gentle press-down instead */
  .ccg-link:active .ccg-cutout {
    transform: rotate(var(--ccg-tilt, 0deg)) scale(0.97);
  }

  @media (prefers-reduced-motion: reduce) {
    .ccg-cutout { transition-duration: 0.01s; }
    .ccg-link:hover .ccg-cutout { transform: rotate(var(--ccg-tilt, 0deg)); }
  }

  .ccg-media {
    aspect-ratio: var(--ccg-ratio, 3/4);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ccg-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    /* Rugged paper edge from the section's SVG filter (dilate +
       noise displacement, paper-toned), then the lifted-page shadow.
       Both follow the PNG alpha. Static — never transitioned. */
    filter: var(--ccg-filter, none) drop-shadow(0 16px 14px rgba(0, 0, 0, 0.28));
  }

  @media screen and (max-width: 749px) {
    .ccg-img {
      filter: var(--ccg-filter, none) drop-shadow(0 10px 10px rgba(0, 0, 0, 0.26));
    }
  }

  .ccg-placeholder-svg {
    width: 100%;
    height: 100%;
    opacity: 0.25;
  }

  /* ── Caption tucked right under the cutout, painted over its shadow ── */
  .ccg-caption {
    position: relative;
    z-index: 1;
    font-size: 0.5rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    opacity: 0.75;
    text-align: center;
    transition: opacity 0.2s ease;
  }

  @media (hover: hover) {
    .ccg-link:hover .ccg-caption { opacity: 1; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection Cutout Grid",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Title",
      "default": "Shop by Collection"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "header",
      "content": "Grid"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" },
        { "value": "6", "label": "6" },
        { "value": "7", "label": "7" },
        { "value": "8", "label": "8" }
      ],
      "default": "8"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns (mobile)",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "1/1", "label": "Square (1:1)" },
        { "value": "3/4", "label": "Portrait (3:4)" },
        { "value": "4/3", "label": "Landscape (4:3)" }
      ],
      "default": "1/1",
      "info": "Sets the space each cutout occupies — the shoe itself keeps its own shape"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0, "max": 120, "step": 4, "unit": "px", "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0, "max": 120, "step": 4, "unit": "px", "default": 48
    }
  ],
  "blocks": [
    {
      "type": "cutout",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection",
          "info": "Image, title and link come from the collection unless overridden below"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom image",
          "info": "Use a PNG with the background removed — the paper edge traces the shoe's outline"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom title"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Custom link"
        }
      ]
    }
  ],
  "max_blocks": 16,
  "presets": [
    {
      "name": "Collection Cutout Grid",
      "blocks": [
        { "type": "cutout" },
        { "type": "cutout" },
        { "type": "cutout" },
        { "type": "cutout" }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
