{% comment %} Floating Instagram widget — homepage & collection pages only {% endcomment %}

<!-- Floating trigger -->
<button id="igw-trigger" aria-label="Follow us on Instagram">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" width="38" height="38">
    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
  </svg>
</button>

<!-- Overlay -->
<div id="igw-overlay" aria-hidden="true" role="dialog" aria-label="Instagram" aria-modal="true">
  <div class="igw-backdrop" id="igw-backdrop"></div>
  <div class="igw-panel">

    <button class="igw-close" id="igw-close" aria-label="Close">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" width="18" height="18">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <div class="igw-header">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="36" height="36">
        <defs>
          <radialGradient id="igw-grad" cx="30%" cy="107%" r="150%">
            <stop offset="0%"  stop-color="#fdf497"/>
            <stop offset="5%"  stop-color="#fdf497"/>
            <stop offset="45%" stop-color="#fd5949"/>
            <stop offset="60%" stop-color="#d6249f"/>
            <stop offset="90%" stop-color="#285AEB"/>
          </radialGradient>
        </defs>
        <path fill="url(#igw-grad)" d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
      </svg>
      <span class="igw-handle">@oceboots</span>
    </div>

    <div class="igw-reels" id="igw-reels">
      {%- if settings.instagram_video_1 != blank -%}
        <div class="igw-reel-wrapper">
          <video class="igw-reel-video" autoplay muted loop playsinline>
            {%- for source in settings.instagram_video_1.sources -%}
              <source src="{{ source.url }}" type="{{ source.mime_type }}">
            {%- endfor -%}
          </video>
        </div>
      {%- endif -%}
      {%- if settings.instagram_video_2 != blank -%}
        <div class="igw-reel-wrapper">
          <video class="igw-reel-video" autoplay muted loop playsinline>
            {%- for source in settings.instagram_video_2.sources -%}
              <source src="{{ source.url }}" type="{{ source.mime_type }}">
            {%- endfor -%}
          </video>
        </div>
      {%- endif -%}
      {%- if settings.instagram_video_3 != blank -%}
        <div class="igw-reel-wrapper">
          <video class="igw-reel-video" autoplay muted loop playsinline>
            {%- for source in settings.instagram_video_3.sources -%}
              <source src="{{ source.url }}" type="{{ source.mime_type }}">
            {%- endfor -%}
          </video>
        </div>
      {%- endif -%}
      {%- if settings.instagram_video_1 == blank and settings.instagram_video_2 == blank and settings.instagram_video_3 == blank -%}
        <p class="igw-reels-empty">Upload reel videos in the theme editor to display them here.</p>
      {%- endif -%}
    </div>

    <a class="igw-see-more" href="https://www.instagram.com/oceboots/" target="_blank" rel="noopener noreferrer">
      <span>Follow on Instagram</span>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
        <line x1="5" y1="12" x2="19" y2="12"/>
        <polyline points="12 5 19 12 12 19"/>
      </svg>
    </a>

  </div>
</div>

<style>
  /* Instagram's exact font stack applied to the entire panel */
  #igw-overlay,
  #igw-trigger {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }

  /* --- Floating trigger --- */
  #igw-trigger {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 9000;
    width: 52px;
    height: 52px;
    border-radius: 12px;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(circle at 30% 107%, #fdf497 0%, #fdf497 5%, #fd5949 45%, #d6249f 60%, #285AEB 90%);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.30);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    padding: 0;
  }

  #igw-trigger:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.38);
  }

  /* --- Overlay --- */
  #igw-overlay {
    position: fixed;
    inset: 0;
    z-index: 9998;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.28s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #igw-overlay.igw-open {
    opacity: 1;
    pointer-events: all;
  }

  .igw-backdrop {
    position: absolute;
    inset: 0;
    backdrop-filter: blur(0px) brightness(1);
    transition: backdrop-filter 0.28s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #igw-overlay.igw-open .igw-backdrop {
    backdrop-filter: blur(18px) brightness(0.45);
  }

  /* --- Panel --- */
  .igw-panel {
    position: relative;
    z-index: 1;
    background: #000000;
    border-radius: 14px;
    width: min(780px, 94vw);
    max-height: 92vh;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 28px 24px 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    transform: translateY(16px);
    transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.6);
  }

  #igw-overlay.igw-open .igw-panel {
    transform: translateY(0);
  }

  /* --- Close --- */
  .igw-close {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 32px;
    height: 32px;
    background: rgba(255, 255, 255, 0.08);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.65);
    transition: background 0.15s, color 0.15s;
    padding: 0;
  }

  .igw-close:hover {
    background: rgba(255, 255, 255, 0.16);
    color: #ffffff;
  }

  /* --- Header --- */
  .igw-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
  }

  .igw-handle {
    color: #ffffff;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  /* --- Reels row --- */
  .igw-reels {
    display: flex;
    gap: 3px;
    width: 100%;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .igw-reels::-webkit-scrollbar {
    display: none;
  }

  .igw-reel-wrapper {
    flex: 0 0 220px;
    height: 390px;
    background: #1a1a1a;
    scroll-snap-align: start;
    overflow: hidden;
  }

  /* First and last get rounded outer corners only */
  .igw-reel-wrapper:first-child {
    border-radius: 4px 0 0 4px;
  }

  .igw-reel-wrapper:last-child {
    border-radius: 0 4px 4px 0;
  }

  .igw-reel-wrapper:only-child {
    border-radius: 4px;
  }

  .igw-reel-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media screen and (min-width: 700px) {
    .igw-reels {
      overflow-x: visible;
      justify-content: center;
    }

    .igw-reel-wrapper {
      flex: 1 1 0;
      max-width: 220px;
    }
  }

  .igw-reels-empty {
    color: rgba(255, 255, 255, 0.35);
    font-size: 0.82rem;
    text-align: center;
    padding: 48px 0;
    width: 100%;
  }

  /* --- See More pill --- */
  .igw-see-more {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin: 20px auto 24px;
    padding: 13px 28px;
    background: radial-gradient(circle at 30% 107%, #fdf497 0%, #fdf497 5%, #fd5949 45%, #d6249f 60%, #285AEB 90%);
    color: #ffffff;
    font-size: 0.95rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    text-decoration: none;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.25);
    border-radius: 999px;
    transition: filter 0.18s ease, transform 0.18s ease;
    box-shadow: 0 4px 16px rgba(214, 36, 159, 0.35);
  }

  .igw-see-more:hover {
    filter: brightness(1.08);
    transform: translateY(-1px);
  }
</style>

<script>
  (function () {
    const trigger  = document.getElementById('igw-trigger');
    const overlay  = document.getElementById('igw-overlay');
    const backdrop = document.getElementById('igw-backdrop');
    const closeBtn = document.getElementById('igw-close');

    function videos() {
      return overlay.querySelectorAll('video');
    }

    function openWidget() {
      overlay.classList.add('igw-open');
      overlay.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      videos().forEach(function (v) { v.play(); });
    }

    function closeWidget() {
      overlay.classList.remove('igw-open');
      overlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      videos().forEach(function (v) { v.pause(); });
    }

    trigger.addEventListener('click', openWidget);
    closeBtn.addEventListener('click', closeWidget);
    backdrop.addEventListener('click', closeWidget);

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && overlay.classList.contains('igw-open')) closeWidget();
    });
  })();
</script>
