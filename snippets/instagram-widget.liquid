{% comment %} Floating Instagram widget — IG profile layout {% endcomment %}

<!-- Floating trigger -->
<button id="igw-trigger" aria-label="Follow us on Instagram">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" width="38" height="38">
    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
  </svg>
</button>

<!-- Overlay -->
<div id="igw-overlay" aria-hidden="true" role="dialog" aria-label="Instagram" aria-modal="true">
  <div class="igw-backdrop" id="igw-backdrop"></div>
  <div class="igw-panel">

    <button class="igw-close" id="igw-close" aria-label="Close">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" width="18" height="18">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <!-- Profile header -->
    <div class="igw-profile">
      <div class="igw-avatar-ring">
        {%- if settings.instagram_avatar != blank -%}
          <img
            src="{{ settings.instagram_avatar | image_url: width: 160 }}"
            alt="@oceboots"
            class="igw-avatar-img"
            width="80"
            height="80"
          >
        {%- else -%}
          <div class="igw-avatar-placeholder">O</div>
        {%- endif -%}
      </div>

      <span class="igw-username">oceboots</span>

      <div class="igw-stats">
        <span class="igw-stat">
          <strong>{{ settings.instagram_follower_count | default: '12.4K' }}</strong>
          <span>Followers</span>
        </span>
      </div>

      <a
        class="igw-follow-btn"
        href="https://www.instagram.com/oceboots/"
        target="_blank"
        rel="noopener noreferrer"
      >Follow</a>
    </div>

    <!-- Reels section -->
    <div class="igw-reels-header">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true">
        <rect x="2" y="2" width="20" height="20" rx="2.5"/>
        <path d="M7 2v20M17 2v20M2 12h20M2 7h5M17 7h5M2 17h5M17 17h5"/>
      </svg>
      <span>Reels</span>
    </div>

    <div class="igw-reels-grid" id="igw-reels">
      {%- if settings.instagram_video_1 != blank -%}
        <div class="igw-reel-cell">
          <video class="igw-reel-video" autoplay muted loop playsinline>
            {%- for source in settings.instagram_video_1.sources -%}
              <source src="{{ source.url }}" type="{{ source.mime_type }}">
            {%- endfor -%}
          </video>
        </div>
      {%- endif -%}
      {%- if settings.instagram_video_2 != blank -%}
        <div class="igw-reel-cell">
          <video class="igw-reel-video" autoplay muted loop playsinline>
            {%- for source in settings.instagram_video_2.sources -%}
              <source src="{{ source.url }}" type="{{ source.mime_type }}">
            {%- endfor -%}
          </video>
        </div>
      {%- endif -%}
      {%- if settings.instagram_video_3 != blank -%}
        <div class="igw-reel-cell">
          <video class="igw-reel-video" autoplay muted loop playsinline>
            {%- for source in settings.instagram_video_3.sources -%}
              <source src="{{ source.url }}" type="{{ source.mime_type }}">
            {%- endfor -%}
          </video>
        </div>
      {%- endif -%}
      {%- if settings.instagram_video_1 == blank and settings.instagram_video_2 == blank and settings.instagram_video_3 == blank -%}
        <p class="igw-reels-empty">Upload reel videos in the theme editor to display them here.</p>
      {%- endif -%}
    </div>

  </div>
</div>

<style>
  #igw-overlay,
  #igw-trigger {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }

  /* --- Floating trigger --- */
  #igw-trigger {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 9000;
    width: 52px;
    height: 52px;
    border-radius: 12px;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(circle at 30% 107%, #ffe000 0%, #ffcc00 5%, #ff2d00 45%, #cc0070 60%, #0040ff 90%);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.30);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    padding: 0;
  }

  #igw-trigger:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.38);
  }

  /* --- Overlay --- */
  #igw-overlay {
    position: fixed;
    inset: 0;
    z-index: 9998;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.28s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #igw-overlay.igw-open {
    opacity: 1;
    pointer-events: all;
  }

  .igw-backdrop {
    position: absolute;
    inset: 0;
    backdrop-filter: blur(0px) brightness(1);
    transition: backdrop-filter 0.28s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #igw-overlay.igw-open .igw-backdrop {
    backdrop-filter: blur(18px) brightness(0.45);
  }

  /* --- Panel (phone-width, IG profile look) --- */
  .igw-panel {
    position: relative;
    z-index: 1;
    background: #000;
    border-radius: 18px;
    width: min(430px, 94vw);
    max-height: 92vh;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-width: none;
    transform: translateY(16px);
    transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.7);
  }

  .igw-panel::-webkit-scrollbar {
    display: none;
  }

  #igw-overlay.igw-open .igw-panel {
    transform: translateY(0);
  }

  /* --- Close button --- */
  .igw-close {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 30px;
    height: 30px;
    background: rgba(255, 255, 255, 0.1);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.7);
    transition: background 0.15s, color 0.15s;
    padding: 0;
    z-index: 2;
  }

  .igw-close:hover {
    background: rgba(255, 255, 255, 0.18);
    color: #fff;
  }

  /* --- Profile header --- */
  .igw-profile {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 32px 20px 20px;
    gap: 10px;
  }

  /* Avatar with IG gradient story ring */
  .igw-avatar-ring {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    padding: 3px;
    background: radial-gradient(circle at 30% 107%, #fdf497 0%, #fdf497 5%, #fd5949 45%, #d6249f 60%, #285AEB 90%);
    flex-shrink: 0;
  }

  .igw-avatar-img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    border: 3px solid #000;
  }

  .igw-avatar-placeholder {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: #262626;
    border: 3px solid #000;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.5);
    font-size: 2rem;
    font-weight: 700;
  }

  .igw-username {
    color: #fff;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.01em;
  }

  /* Stats row — only followers shown */
  .igw-stats {
    display: flex;
    gap: 32px;
  }

  .igw-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1px;
    color: #fff;
    font-size: 0.85rem;
  }

  .igw-stat strong {
    font-size: 1rem;
    font-weight: 700;
  }

  .igw-stat span {
    color: rgba(255,255,255,0.6);
    font-size: 0.78rem;
  }

  /* Follow button — IG blue pill */
  .igw-follow-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 34px;
    padding: 0 48px;
    background: #0095f6;
    color: #fff;
    font-size: 0.88rem;
    font-weight: 700;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.15s;
    letter-spacing: 0.01em;
    margin-top: 2px;
  }

  .igw-follow-btn:hover {
    background: #1aa3ff;
  }

  /* --- Reels section header --- */
  .igw-reels-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    border-top: 1px solid rgba(255,255,255,0.15);
    padding: 12px 0;
    color: rgba(255,255,255,0.85);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* --- Reels grid (3 columns, like IG) --- */
  .igw-reels-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }

  .igw-reel-cell {
    aspect-ratio: 9 / 16;
    overflow: hidden;
    background: #111;
  }

  .igw-reel-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .igw-reels-empty {
    grid-column: 1 / -1;
    color: rgba(255,255,255,0.35);
    font-size: 0.82rem;
    text-align: center;
    padding: 48px 20px;
  }
</style>

<script>
  (function () {
    const trigger  = document.getElementById('igw-trigger');
    const overlay  = document.getElementById('igw-overlay');
    const backdrop = document.getElementById('igw-backdrop');
    const closeBtn = document.getElementById('igw-close');

    function videos() {
      return overlay.querySelectorAll('video');
    }

    function openWidget() {
      overlay.classList.add('igw-open');
      overlay.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      videos().forEach(function (v) { v.play(); });
    }

    function closeWidget() {
      overlay.classList.remove('igw-open');
      overlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      videos().forEach(function (v) { v.pause(); });
    }

    trigger.addEventListener('click', openWidget);
    closeBtn.addEventListener('click', closeWidget);
    backdrop.addEventListener('click', closeWidget);

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && overlay.classList.contains('igw-open')) closeWidget();
    });
  })();
</script>
