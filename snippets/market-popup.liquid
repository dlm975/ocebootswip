<div
  id="mkt-overlay"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="Select your region"
>
  <div class="mkt-backdrop" id="mkt-backdrop"></div>
  <div class="mkt-panel">

    <h2 class="mkt-title">Choose your region</h2>
    <p class="mkt-subtitle">Select your location for correct pricing &amp; shipping.</p>

    {%- form 'localization', id: 'mkt-form' -%}

      <!-- Detected market card -->
      <button
        type="submit"
        class="mkt-detected"
        name="country_code"
        value="{{ localization.country.iso_code }}"
        id="mkt-detected-btn"
      >
        <span class="mkt-flag-circle">
          <img
            src="https://flagcdn.com/w80/{{ localization.country.iso_code | downcase }}.png"
            width="80"
            height="60"
            alt="{{ localization.country.name }} flag"
            onerror="this.style.display='none'"
          >
        </span>
        <span class="mkt-info">
          <span class="mkt-name">{{ localization.country.name }}</span>
          <span class="mkt-currency">{{ localization.country.currency.iso_code }} {{ localization.country.currency.symbol }}</span>
        </span>
        <span class="mkt-tick" aria-hidden="true">
          <svg viewBox="0 0 12 12" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="1.5 6 4.5 9.5 10.5 2.5"/>
          </svg>
        </span>
      </button>

      <button type="button" class="mkt-confirm" id="mkt-confirm">Continue</button>

      <div class="mkt-divider">
        <span>or search for a different region</span>
      </div>

      <div class="mkt-search-wrap">
        <svg class="mkt-search-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="15" height="15" aria-hidden="true">
          <circle cx="8.5" cy="8.5" r="5.5"/>
          <line x1="13" y1="13" x2="18" y2="18"/>
        </svg>
        <input
          type="text"
          id="mkt-search"
          class="mkt-search"
          placeholder="Search country…"
          autocomplete="off"
          spellcheck="false"
          aria-label="Search countries"
          aria-controls="mkt-list"
        >
      </div>

      <div class="mkt-list" id="mkt-list" role="listbox" hidden>
        {%- for country in localization.available_countries -%}
          {%- unless country.iso_code == localization.country.iso_code -%}
            <button
              type="submit"
              class="mkt-option"
              name="country_code"
              value="{{ country.iso_code }}"
              data-name="{{ country.name | downcase }}"
              role="option"
              aria-selected="false"
            >
              <span class="mkt-flag-circle">
                <img
                  src="https://flagcdn.com/w80/{{ country.iso_code | downcase }}.png"
                  width="80"
                  height="60"
                  alt="{{ country.name }} flag"
                  loading="lazy"
                  onerror="this.style.display='none'"
                >
              </span>
              <span class="mkt-info">
                <span class="mkt-name">{{ country.name }}</span>
                <span class="mkt-currency">{{ country.currency.iso_code }} {{ country.currency.symbol }}</span>
              </span>
            </button>
          {%- endunless -%}
        {%- endfor -%}
      </div>
      <p class="mkt-no-results" id="mkt-no-results" hidden>No countries found.</p>

    {%- endform -%}

  </div>
</div>

<style>
  #mkt-overlay {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }

  #mkt-overlay.mkt-open {
    opacity: 1;
    pointer-events: all;
  }

  .mkt-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0);
    backdrop-filter: blur(0px) brightness(1);
    transition: backdrop-filter 0.3s cubic-bezier(0.4, 0, 0.2, 1), background 0.3s;
  }

  #mkt-overlay.mkt-open .mkt-backdrop {
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(12px) brightness(0.55);
  }

  .mkt-panel {
    position: relative;
    z-index: 1;
    background: #111;
    color: #fff;
    border-radius: 20px;
    width: min(400px, 92vw);
    padding: 28px 24px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.7);
    transform: translateY(18px) scale(0.97);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #mkt-overlay.mkt-open .mkt-panel {
    transform: translateY(0) scale(1);
  }

  .mkt-title {
    font-size: 1rem;
    font-weight: 700;
    margin: 0;
    color: #fff;
  }

  .mkt-subtitle {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.4);
    margin: 0;
    text-align: center;
  }

  /* Detected country card */
  .mkt-detected {
    display: flex;
    align-items: center;
    gap: 14px;
    width: 100%;
    padding: 12px 14px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 14px;
    color: #fff;
    font-family: inherit;
    cursor: pointer;
    text-align: left;
    margin-top: 4px;
    transition: background 0.13s, border-color 0.13s;
  }

  .mkt-detected:hover {
    background: rgba(255, 255, 255, 0.14);
    border-color: rgba(255, 255, 255, 0.28);
  }

  /* Continue button */
  .mkt-confirm {
    width: 100%;
    padding: 13px;
    background: #fff;
    color: #111;
    border: none;
    border-radius: 12px;
    font-family: inherit;
    font-size: 0.9rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.13s;
  }

  .mkt-confirm:hover {
    background: rgba(255, 255, 255, 0.88);
  }

  /* Divider */
  .mkt-divider {
    display: flex;
    align-items: center;
    width: 100%;
    gap: 10px;
    margin: 2px 0;
  }

  .mkt-divider::before,
  .mkt-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
  }

  .mkt-divider span {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.28);
    white-space: nowrap;
  }

  /* Search */
  .mkt-search-wrap {
    position: relative;
    width: 100%;
  }

  .mkt-search-icon {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: rgba(255, 255, 255, 0.35);
    pointer-events: none;
  }

  .mkt-search {
    width: 100%;
    box-sizing: border-box;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 10px;
    padding: 10px 12px 10px 36px;
    color: #fff;
    font-family: inherit;
    font-size: 0.85rem;
    outline: none;
    transition: border-color 0.15s, background 0.15s;
  }

  .mkt-search::placeholder {
    color: rgba(255, 255, 255, 0.3);
  }

  .mkt-search:focus {
    border-color: rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.11);
  }

  /* Scrollable list */
  .mkt-list {
    width: 100%;
    max-height: 260px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 2px;
    scrollbar-width: thin;
    scrollbar-color: rgba(255, 255, 255, 0.15) transparent;
  }

  .mkt-option {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
    padding: 8px 10px;
    background: transparent;
    border: 1px solid transparent;
    border-radius: 11px;
    color: rgba(255, 255, 255, 0.7);
    font-family: inherit;
    cursor: pointer;
    text-align: left;
    transition: background 0.13s, border-color 0.13s, color 0.13s;
  }

  .mkt-option:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.12);
    color: #fff;
  }

  /* Circular flag image */
  .mkt-flag-circle {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background: rgba(255, 255, 255, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mkt-flag-circle img {
    width: 50px;
    height: 50px;
    object-fit: cover;
    display: block;
  }

  .mkt-info {
    display: flex;
    flex-direction: column;
    gap: 1px;
    flex: 1;
    min-width: 0;
  }

  .mkt-name {
    font-size: 0.85rem;
    font-weight: 600;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .mkt-currency {
    font-size: 0.71rem;
    color: rgba(255, 255, 255, 0.38);
  }

  .mkt-detected .mkt-currency {
    color: rgba(255, 255, 255, 0.55);
  }

  .mkt-tick {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #fff;
    color: #111;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-left: auto;
  }

  .mkt-no-results {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.35);
    text-align: center;
    margin: 4px 0 0;
    width: 100%;
  }
</style>

<script>
  (function () {
    var STORAGE_KEY = 'oce_market_confirmed';
    var overlay     = document.getElementById('mkt-overlay');
    var backdrop    = document.getElementById('mkt-backdrop');
    var confirmBtn  = document.getElementById('mkt-confirm');
    var detectedBtn = document.getElementById('mkt-detected-btn');
    var searchInput = document.getElementById('mkt-search');
    var list        = document.getElementById('mkt-list');
    var noResults   = document.getElementById('mkt-no-results');
    var options     = Array.prototype.slice.call(list.querySelectorAll('.mkt-option'));

    if (localStorage.getItem(STORAGE_KEY)) return;

    /* Show list and filter as user types */
    searchInput.addEventListener('input', function () {
      var q = searchInput.value.trim().toLowerCase();
      if (!q) {
        list.hidden = true;
        noResults.hidden = true;
        return;
      }
      list.hidden = false;
      var visible = 0;
      options.forEach(function (btn) {
        var match = btn.dataset.name.indexOf(q) !== -1;
        btn.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      noResults.hidden = visible > 0;
    });

    function open() {
      overlay.classList.add('mkt-open');
      overlay.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function close() {
      localStorage.setItem(STORAGE_KEY, '1');
      overlay.classList.remove('mkt-open');
      overlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    setTimeout(open, 500);

    confirmBtn.addEventListener('click', close);
    detectedBtn.addEventListener('click', function () {
      localStorage.setItem(STORAGE_KEY, '1');
    });
    options.forEach(function (btn) {
      btn.addEventListener('click', function () {
        localStorage.setItem(STORAGE_KEY, '1');
      });
    });

    backdrop.addEventListener('click', close);

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && overlay.classList.contains('mkt-open')) close();
    });
  })();
</script>
