<div
  id="mkt-overlay"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="Select your region"
>
  <div class="mkt-backdrop" id="mkt-backdrop"></div>
  <div class="mkt-panel">

    <h2 class="mkt-title">Choose your region</h2>
    <p class="mkt-subtitle">Select your location for correct pricing &amp; shipping.</p>

    {%- form 'localization', id: 'mkt-form' -%}
      <div class="mkt-list">
        {%- for country in localization.available_countries -%}
          <button
            type="submit"
            class="mkt-option{% if country.iso_code == localization.country.iso_code %} mkt-option--current{% endif %}"
            name="country_code"
            value="{{ country.iso_code }}"
          >
            <span class="mkt-flag-circle">{{ country.flag_pictogram }}</span>
            <span class="mkt-info">
              <span class="mkt-name">{{ country.name }}</span>
              <span class="mkt-currency">{{ country.currency.iso_code }} {{ country.currency.symbol }}</span>
            </span>
            {%- if country.iso_code == localization.country.iso_code -%}
              <span class="mkt-tick" aria-label="Current region">
                <svg viewBox="0 0 12 12" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="1.5 6 4.5 9.5 10.5 2.5"/>
                </svg>
              </span>
            {%- endif -%}
          </button>
        {%- endfor -%}
      </div>
    {%- endform -%}

    <button class="mkt-dismiss" id="mkt-dismiss">Continue without changing</button>

  </div>
</div>

<style>
  #mkt-overlay {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }

  #mkt-overlay.mkt-open {
    opacity: 1;
    pointer-events: all;
  }

  .mkt-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0);
    backdrop-filter: blur(0px) brightness(1);
    transition: backdrop-filter 0.3s cubic-bezier(0.4, 0, 0.2, 1), background 0.3s;
  }

  #mkt-overlay.mkt-open .mkt-backdrop {
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(12px) brightness(0.55);
  }

  .mkt-panel {
    position: relative;
    z-index: 1;
    background: #111;
    color: #fff;
    border-radius: 20px;
    width: min(400px, 92vw);
    padding: 28px 24px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.7);
    transform: translateY(18px) scale(0.97);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #mkt-overlay.mkt-open .mkt-panel {
    transform: translateY(0) scale(1);
  }

  .mkt-title {
    font-size: 1rem;
    font-weight: 700;
    margin: 0;
    color: #fff;
  }

  .mkt-subtitle {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.45);
    margin: 0;
    text-align: center;
  }

  /* Scrollable list */
  .mkt-list {
    width: 100%;
    max-height: 320px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 4px;
    scrollbar-width: thin;
    scrollbar-color: rgba(255, 255, 255, 0.15) transparent;
  }

  .mkt-option {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
    padding: 9px 10px;
    background: transparent;
    border: 1px solid transparent;
    border-radius: 12px;
    color: rgba(255, 255, 255, 0.75);
    font-family: inherit;
    cursor: pointer;
    text-align: left;
    transition: background 0.14s, border-color 0.14s, color 0.14s;
  }

  .mkt-option:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.12);
    color: #fff;
  }

  .mkt-option--current {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
    color: #fff;
  }

  /* Circular flag */
  .mkt-flag-circle {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    flex-shrink: 0;
    overflow: hidden;
  }

  .mkt-info {
    display: flex;
    flex-direction: column;
    gap: 1px;
    flex: 1;
    min-width: 0;
  }

  .mkt-name {
    font-size: 0.85rem;
    font-weight: 600;
    line-height: 1.2;
  }

  .mkt-currency {
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.4);
  }

  .mkt-option--current .mkt-currency {
    color: rgba(255, 255, 255, 0.55);
  }

  .mkt-tick {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #fff;
    color: #111;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-left: auto;
  }

  .mkt-dismiss {
    font-family: inherit;
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.25);
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px 8px;
    transition: color 0.15s;
  }

  .mkt-dismiss:hover {
    color: rgba(255, 255, 255, 0.5);
  }
</style>

<script>
  (function () {
    var STORAGE_KEY = 'oce_market_confirmed';
    var overlay    = document.getElementById('mkt-overlay');
    var backdrop   = document.getElementById('mkt-backdrop');
    var dismissBtn = document.getElementById('mkt-dismiss');

    if (localStorage.getItem(STORAGE_KEY)) return;

    function open() {
      overlay.classList.add('mkt-open');
      overlay.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function close() {
      localStorage.setItem(STORAGE_KEY, '1');
      overlay.classList.remove('mkt-open');
      overlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    setTimeout(open, 500);

    document.querySelectorAll('#mkt-form button').forEach(function (btn) {
      btn.addEventListener('click', function () {
        localStorage.setItem(STORAGE_KEY, '1');
      });
    });

    dismissBtn.addEventListener('click', close);
    backdrop.addEventListener('click', close);

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && overlay.classList.contains('mkt-open')) close();
    });
  })();
</script>
