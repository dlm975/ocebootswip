<div
  id="mkt-overlay"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="Select your region"
>
  <div class="mkt-panel">

    <div class="mkt-header">
      <h2 class="mkt-title">Choose your region</h2>
      <button type="button" class="mkt-close" id="mkt-close" aria-label="Close">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" width="16" height="16" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    {%- form 'localization', id: 'mkt-form' -%}

      <div class="mkt-scroller" id="mkt-scroller">

        <!-- Current country first, highlighted -->
        <button
          type="submit"
          class="mkt-row mkt-row--current"
          name="country_code"
          value="{{ localization.country.iso_code }}"
        >
          <span class="mkt-flag">
            <img
              src="https://flagcdn.com/w80/{{ localization.country.iso_code | downcase }}.png"
              width="80" height="60"
              alt="{{ localization.country.name }} flag"
              onerror="this.style.display='none'"
            >
          </span>
          <span class="mkt-row__info">
            <span class="mkt-row__name">{{ localization.country.name }}</span>
            <span class="mkt-row__currency">{{ localization.country.currency.iso_code }} {{ localization.country.currency.symbol }}</span>
          </span>
          <span class="mkt-row__check" aria-hidden="true">
            <svg viewBox="0 0 12 12" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="1.5 6 4.5 9.5 10.5 2.5"/>
            </svg>
          </span>
        </button>

        <!-- All other available countries -->
        {%- for country in localization.available_countries -%}
          {%- unless country.iso_code == localization.country.iso_code -%}
            <button
              type="submit"
              class="mkt-row"
              name="country_code"
              value="{{ country.iso_code }}"
            >
              <span class="mkt-flag">
                <img
                  src="https://flagcdn.com/w80/{{ country.iso_code | downcase }}.png"
                  width="80" height="60"
                  alt="{{ country.name }} flag"
                  loading="lazy"
                  onerror="this.style.display='none'"
                >
              </span>
              <span class="mkt-row__info">
                <span class="mkt-row__name">{{ country.name }}</span>
                <span class="mkt-row__currency">{{ country.currency.iso_code }} {{ country.currency.symbol }}</span>
              </span>
            </button>
          {%- endunless -%}
        {%- endfor -%}

      </div>

    {%- endform -%}

  </div>
</div>

<style>
  #mkt-overlay {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    background: rgba(0, 0, 0, 0);
    backdrop-filter: blur(0px) brightness(1);
    opacity: 0;
    transition: opacity 0.28s cubic-bezier(0.4, 0, 0.2, 1),
                backdrop-filter 0.28s cubic-bezier(0.4, 0, 0.2, 1),
                background 0.28s cubic-bezier(0.4, 0, 0.2, 1);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }

  #mkt-overlay.mkt-open {
    opacity: 1;
    pointer-events: auto;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(14px) brightness(0.5);
  }

  .mkt-panel {
    background: #111;
    color: #fff;
    border-radius: 22px;
    width: min(380px, 92vw);
    max-height: min(560px, 82vh);
    display: flex;
    flex-direction: column;
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.7);
    transform: translateY(16px) scale(0.97);
    transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
  }

  #mkt-overlay.mkt-open .mkt-panel {
    transform: translateY(0) scale(1);
  }

  .mkt-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 20px 0;
    flex-shrink: 0;
  }

  .mkt-title {
    font-size: 0.95rem;
    font-weight: 700;
    margin: 0;
    color: #fff;
  }

  .mkt-close {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.65);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
    transition: background 0.13s, color 0.13s;
  }

  .mkt-close:hover {
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
  }

  .mkt-scroller {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    padding: 12px 12px 16px;
    display: flex;
    flex-direction: column;
    gap: 3px;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: rgba(255, 255, 255, 0.15) transparent;
  }

  .mkt-scroller::-webkit-scrollbar {
    width: 4px;
  }

  .mkt-scroller::-webkit-scrollbar-track {
    background: transparent;
  }

  .mkt-scroller::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.15);
    border-radius: 2px;
  }

  .mkt-row {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
    padding: 9px 10px;
    background: transparent;
    border: 1px solid transparent;
    border-radius: 12px;
    color: rgba(255, 255, 255, 0.72);
    font-family: inherit;
    cursor: pointer;
    text-align: left;
    transition: background 0.12s, border-color 0.12s, color 0.12s;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
  }

  .mkt-row:hover,
  .mkt-row:active {
    background: rgba(255, 255, 255, 0.09);
    border-color: rgba(255, 255, 255, 0.13);
    color: #fff;
  }

  .mkt-row--current {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
    color: #fff;
    margin-bottom: 6px;
  }

  .mkt-row--current:hover,
  .mkt-row--current:active {
    background: rgba(255, 255, 255, 0.14);
  }

  .mkt-flag {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background: rgba(255, 255, 255, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mkt-flag img {
    width: 48px;
    height: 48px;
    object-fit: cover;
    display: block;
  }

  .mkt-row__info {
    display: flex;
    flex-direction: column;
    gap: 1px;
    flex: 1;
    min-width: 0;
  }

  .mkt-row__name {
    font-size: 0.84rem;
    font-weight: 600;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .mkt-row__currency {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.38);
  }

  .mkt-row--current .mkt-row__currency {
    color: rgba(255, 255, 255, 0.55);
  }

  .mkt-row__check {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #fff;
    color: #111;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
</style>

<script>
  (function () {
    var STORAGE_KEY = 'oce_market_confirmed';
    var overlay    = document.getElementById('mkt-overlay');
    var closeBtn   = document.getElementById('mkt-close');

    var savedScrollY = 0;

    function lockScroll() {
      savedScrollY = window.scrollY;
      document.body.style.position = 'fixed';
      document.body.style.top = '-' + savedScrollY + 'px';
      document.body.style.width = '100%';
    }

    function unlockScroll() {
      document.body.style.position = '';
      document.body.style.top = '';
      document.body.style.width = '';
      window.scrollTo(0, savedScrollY);
    }

    function open() {
      overlay.classList.add('mkt-open');
      overlay.setAttribute('aria-hidden', 'false');
      lockScroll();
    }

    function close() {
      localStorage.setItem(STORAGE_KEY, '1');
      overlay.classList.remove('mkt-open');
      overlay.setAttribute('aria-hidden', 'true');
      unlockScroll();
    }

    /* Save confirmed state when any country row is clicked */
    overlay.querySelectorAll('.mkt-row').forEach(function (btn) {
      btn.addEventListener('click', function () {
        localStorage.setItem(STORAGE_KEY, '1');
      });
    });

    closeBtn.addEventListener('click', close);

    /* Tap outside panel closes */
    overlay.addEventListener('click', function (e) {
      if (!e.target.closest('.mkt-panel')) close();
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && overlay.classList.contains('mkt-open')) close();
    });

    /* Auto-show only on collection pages, 3 s after load */
    {%- if template.name == 'collection' -%}
    if (!localStorage.getItem(STORAGE_KEY)) {
      setTimeout(open, 3000);
    }
    {%- endif -%}

    /* Manual trigger from drawer button */
    document.addEventListener('mkt:open', open);
  })();
</script>
