<script
  src="{{ 'dialog.js' | asset_url }}"
  type="module"
></script>

<dialog-component
  id="search-modal"
  class="search-modal"
  {{ block.shopify_attributes }}
>
  <dialog
    ref="dialog"
    on:click="/closeDialogOnClickOutside"
    on:keydown="/closeDialogOnEscapePress"
    class="search-modal__content dialog-modal"
    scroll-lock
  >
    {% render 'predictive-search',
      input_id: 'cmdk-input',
      search_test_id: 'search-component--modal',
      products_test_id: 'products-list-default--modal'
    %}
  </dialog>
</dialog-component>

{% stylesheet %}
  /* Search modal style */
  .search-modal {
    --search-border-radius: var(--style-border-radius-popover);
    --search-border-width: var(--style-border-width);
  }

  .search-modal__button {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Centered pill layout */
  .search-modal__content {
    --modal-width: min(600px, 90vw);

    padding: 0;
    border-radius: 9999px;

    @media screen and (min-width: 750px) {
      width: var(--modal-width);
      /* True vertical + horizontal centering */
      inset: 0;
      margin: auto;
      overflow: hidden;
    }
  }

  /* When results are visible, relax pill to rounded rectangle */
  .search-modal__content:has(.predictive-search-form__content-wrapper:not([hidden])) {
    border-radius: var(--search-border-radius);
    border-end-start-radius: var(--search-border-radius);
    border-end-end-radius: var(--search-border-radius);
  }

  /* Pill-shaped search input row */
  .search-modal__content .predictive-search-form__header {
    border-radius: 9999px;
    overflow: hidden;
  }

  /* Relax header pill when results appear below it */
  .search-modal__content:has(.predictive-search-form__content-wrapper:not([hidden])) .predictive-search-form__header {
    border-radius: var(--search-border-radius) var(--search-border-radius) 0 0;
  }

  /* Blurred + dimmed backdrop */
  @keyframes search-backdrop-in {
    from {
      backdrop-filter: blur(0px) brightness(1);
      background-color: rgb(0 0 0 / 0);
    }
    to {
      backdrop-filter: blur(14px) brightness(0.55);
      background-color: rgb(0 0 0 / 0.2);
    }
  }

  @keyframes search-backdrop-out {
    from {
      backdrop-filter: blur(14px) brightness(0.55);
      background-color: rgb(0 0 0 / 0.2);
    }
    to {
      backdrop-filter: blur(0px) brightness(1);
      background-color: rgb(0 0 0 / 0);
    }
  }

  /* Override the default backdrop animation for search only */
  .dialog-modal[open].search-modal__content::backdrop {
    animation: search-backdrop-in 300ms var(--ease-out-quad) forwards;
  }

  .dialog-modal.search-modal__content.dialog-closing::backdrop {
    animation: search-backdrop-out 200ms var(--ease-out-quad) forwards;
  }

  /* Hide the default dialog backdrop on small screens */
  @media screen and (max-width: 749px) {
    .search-modal__content::backdrop {
      display: none;
    }
  }

  /* Opening animation: fade + scale from center instead of bottom slide */
  @keyframes search-modal-appear {
    from {
      opacity: 0;
      transform: scale(0.95) translateY(-6px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  @keyframes search-modal-disappear {
    from {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
    to {
      opacity: 0;
      transform: scale(0.95) translateY(-6px);
    }
  }

  .dialog-modal[open].search-modal__content {
    transform-origin: center top;
    animation: search-modal-appear 250ms var(--ease-out-quad) forwards;
    box-shadow: 0 8px 40px rgb(0 0 0 / 0.18), 0 2px 8px rgb(0 0 0 / 0.1);

    @media screen and (max-width: 749px) {
      border-radius: 0;
    }
  }

  .dialog-modal.search-modal__content.dialog-closing {
    animation: search-modal-disappear 180ms var(--ease-out-quad) forwards;
  }

  .search-modal__content[open] {
    display: flex;
  }

  .search-modal__content :is(.predictive-search-dropdown, .predictive-search-form__content-wrapper) {
    position: relative;
  }

  /* Predictive search header tweaks for small screens */
  @media screen and (max-width: 749px) {
    .dialog-modal
      .predictive-search-form__header:has(
        .predictive-search__reset-button:not(.predictive-search__reset-button[hidden])
      )::before {
      content: '';
      position: absolute;
      right: calc(var(--padding-sm) + var(--minimum-touch-target));
      top: 0;
      bottom: 0;
      width: var(--border-width-sm);
      background-color: var(--color-border);
    }

    .dialog-modal
      .predictive-search-form__header:has(
        .predictive-search__reset-button:not(.predictive-search__reset-button[hidden])
      )
      > .predictive-search__close-modal-button {
      &::before {
        content: none;
      }
    }
  }
{% endstylesheet %}
