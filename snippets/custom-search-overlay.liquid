<div id="cs-overlay" aria-hidden="true" role="dialog" aria-label="Search" aria-modal="true">
  <div class="cs-backdrop" id="cs-backdrop"></div>
  <div class="cs-center">
    <form class="cs-form" id="cs-form" action="{{ routes.search_url }}" method="get" autocomplete="off">
      <input type="hidden" name="type" value="product">
      <div class="cs-field">
        <input
          id="cs-input"
          class="cs-input"
          type="search"
          name="q"
          spellcheck="false"
          aria-label="Search"
        >
        <div class="cs-prompts" id="cs-prompts" aria-hidden="true">
          <span id="cs-prompt-text"></span>
        </div>
      </div>
      <p class="cs-hint">Press <kbd>Enter</kbd> to search &middot; <kbd>Esc</kbd> to close</p>
    </form>
  </div>
</div>

<style>
  #cs-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.28s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #cs-overlay.cs-open {
    opacity: 1;
    pointer-events: all;
  }

  .cs-backdrop {
    position: absolute;
    inset: 0;
    backdrop-filter: blur(0px) brightness(1);
    transition: backdrop-filter 0.28s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #cs-overlay.cs-open .cs-backdrop {
    backdrop-filter: blur(16px) brightness(0.5);
  }

  .cs-center {
    position: relative;
    z-index: 1;
    width: min(512px, 70vw);
    text-align: center;
    transform: translateY(-12px);
    transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #cs-overlay.cs-open .cs-center {
    transform: translateY(0);
  }

  .cs-field {
    position: relative;
    display: flex;
    align-items: center;
    border-bottom: 1.5px solid rgba(255, 255, 255, 0.7);
    padding-bottom: 10px;
  }

  .cs-input {
    width: 100%;
    background: transparent;
    border: none;
    outline: none;
    color: #ffffff;
    font-size: clamp(1.4rem, 3.5vw, 2.4rem);
    font-family: inherit;
    font-weight: 400;
    letter-spacing: -0.01em;
    text-align: center;
    padding: 0;
    caret-color: #ffffff;
    appearance: none;
    position: relative;
    z-index: 1;
  }

  /* hide browser's native ✕ clear button */
  .cs-input::-webkit-search-cancel-button,
  .cs-input::-webkit-search-decoration {
    display: none;
  }

  /* cycling prompt overlay — sits behind the input text */
  .cs-prompts {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    color: rgba(255, 255, 255, 0.32);
    font-size: clamp(1.4rem, 3.5vw, 2.4rem);
    font-family: inherit;
    font-weight: 400;
    letter-spacing: -0.01em;
    transition: opacity 0.35s ease;
  }

  .cs-prompts.cs-prompt-fade {
    opacity: 0;
  }

  /* hide prompts when user has typed anything */
  .cs-prompts.cs-prompt-hidden {
    display: none;
  }

  .cs-hint {
    margin-top: 18px;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: 0.04em;
    font-family: inherit;
  }

  .cs-hint kbd {
    font-family: inherit;
    font-size: inherit;
    background: rgba(255, 255, 255, 0.12);
    border-radius: 4px;
    padding: 1px 5px;
  }
</style>

<script>
  (function () {
    const overlay   = document.getElementById('cs-overlay');
    const input     = document.getElementById('cs-input');
    const backdrop  = document.getElementById('cs-backdrop');
    const form      = document.getElementById('cs-form');
    const promptsEl = document.getElementById('cs-prompts');
    const promptText = document.getElementById('cs-prompt-text');

    const prompts = ['mercurial vapor', 'f50', 'nike tiempo', 'fg studs'];
    let promptIdx = 0;
    let promptTimer = null;

    function showPrompt(text) {
      promptsEl.classList.remove('cs-prompt-fade');
      promptText.textContent = text;
    }

    function cyclePrompt() {
      promptsEl.classList.add('cs-prompt-fade');
      setTimeout(function () {
        promptIdx = (promptIdx + 1) % prompts.length;
        promptText.textContent = prompts[promptIdx];
        promptsEl.classList.remove('cs-prompt-fade');
      }, 350);
    }

    function startPrompts() {
      promptIdx = 0;
      showPrompt(prompts[0]);
      promptsEl.classList.remove('cs-prompt-hidden');
      promptTimer = setInterval(cyclePrompt, 2400);
    }

    function stopPrompts() {
      clearInterval(promptTimer);
      promptTimer = null;
    }

    input.addEventListener('input', function () {
      if (input.value.length > 0) {
        promptsEl.classList.add('cs-prompt-hidden');
        stopPrompts();
      } else {
        promptsEl.classList.remove('cs-prompt-hidden');
        startPrompts();
      }
    });

    function openSearch() {
      overlay.classList.add('cs-open');
      overlay.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      input.value = '';
      startPrompts();
      setTimeout(function () { input.focus(); }, 40);
    }

    function closeSearch() {
      overlay.classList.remove('cs-open');
      overlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      input.value = '';
      stopPrompts();
    }

    backdrop.addEventListener('click', closeSearch);

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && overlay.classList.contains('cs-open')) {
        closeSearch();
      }
    });

    form.addEventListener('submit', function (e) {
      if (!input.value.trim()) { e.preventDefault(); }
    });

    window.customSearchOpen  = openSearch;
    window.customSearchClose = closeSearch;
  })();
</script>
