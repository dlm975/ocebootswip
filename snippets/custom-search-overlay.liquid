<div id="cs-overlay" aria-hidden="true" role="dialog" aria-label="Search" aria-modal="true">
  <div class="cs-backdrop" id="cs-backdrop"></div>

  <button class="cs-close" id="cs-close" aria-label="Close search">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" width="18" height="18" aria-hidden="true">
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>

  <div class="cs-center">
    <div class="cs-row">
      <form class="cs-form" id="cs-form" action="{{ routes.search_url }}" method="get" autocomplete="off">
        <input type="hidden" name="type" value="product">
        <div class="cs-field">
          <svg class="cs-glass" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
            <circle cx="11" cy="11" r="7"/>
            <line x1="16.5" y1="16.5" x2="21" y2="21"/>
          </svg>
          <input
            id="cs-input"
            class="cs-input"
            type="search"
            name="q"
            spellcheck="false"
            enterkeyhint="search"
            aria-label="Search"
          >
          <div class="cs-prompts" id="cs-prompts" aria-hidden="true">
            <span id="cs-prompt-text"></span>
          </div>
          <button type="submit" class="cs-submit" id="cs-submit" aria-label="Submit search">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </button>
        </div>
      </form>
      <button type="button" class="cs-cancel" id="cs-cancel">Cancel</button>
    </div>
    <p class="cs-hint"><kbd>Esc</kbd> to close</p>
  </div>
</div>

<style>
  #cs-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease-out;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }

  #cs-overlay.cs-open {
    opacity: 1;
    pointer-events: all;
    /* block background page scroll on touch without locking body */
    touch-action: none;
  }

  /* Static blur, faded in by the overlay's own opacity — animating
     backdrop-filter itself is what caused the jank */
  .cs-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.42);
    -webkit-backdrop-filter: blur(22px) saturate(160%);
    backdrop-filter: blur(22px) saturate(160%);
  }

  /* Spotlight-style: anchored to the upper third so the iOS keyboard
     never collides with or jumps the field */
  .cs-center {
    position: relative;
    z-index: 1;
    width: min(560px, 92vw);
    margin-top: max(18vh, calc(16px + env(safe-area-inset-top, 0px)));
    transform: scale(0.97) translateY(-8px);
    transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  }

  #cs-overlay.cs-open .cs-center {
    transform: scale(1) translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    #cs-overlay, .cs-center { transition-duration: 0.01s; }
  }

  .cs-row {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .cs-form { flex: 1; min-width: 0; }

  /* Frosted dark-glass pill field (iOS search bar material) */
  .cs-field {
    position: relative;
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(28, 28, 30, 0.72);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    backdrop-filter: blur(24px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 16px;
    padding: 13px 14px;
    box-shadow: 0 24px 48px -16px rgba(0, 0, 0, 0.5), 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  .cs-glass {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    color: rgba(255, 255, 255, 0.45);
  }

  .cs-input {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: none;
    outline: none;
    color: #ffffff;
    font-size: 1.15rem; /* ≥16px so iOS never auto-zooms */
    font-family: inherit;
    font-weight: 400;
    letter-spacing: -0.01em;
    text-align: left;
    padding: 0;
    caret-color: #0a84ff;
    appearance: none;
    position: relative;
    z-index: 1;
  }

  /* hide browser's native ✕ clear button */
  .cs-input::-webkit-search-cancel-button,
  .cs-input::-webkit-search-decoration {
    display: none;
  }

  /* cycling prompt — sits behind the input text, aligned with it */
  .cs-prompts {
    position: absolute;
    left: 44px;
    right: 48px;
    top: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    pointer-events: none;
    color: rgba(255, 255, 255, 0.35);
    font-size: 1.15rem;
    font-family: inherit;
    letter-spacing: -0.01em;
    white-space: nowrap;
    overflow: hidden;
    opacity: 1;
    transition: opacity 0.3s ease;
  }

  .cs-prompts.cs-prompt-fade { opacity: 0; }
  .cs-prompts.cs-prompt-hidden { display: none; }

  /* Submit arrow — only visible once there's a query */
  .cs-submit {
    flex-shrink: 0;
    width: 30px;
    height: 30px;
    border: none;
    border-radius: 50%;
    background: #ffffff;
    color: #111111;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: scale(0.6);
    pointer-events: none;
    -webkit-tap-highlight-color: transparent;
    transition: opacity 0.2s ease, transform 0.25s cubic-bezier(0.32, 0.72, 0, 1);
  }

  .cs-field.cs-has-query .cs-submit {
    opacity: 1;
    transform: scale(1);
    pointer-events: auto;
  }

  .cs-submit:active { transform: scale(0.88); }

  /* iOS Cancel button — touch devices only */
  .cs-cancel {
    display: none;
    flex-shrink: 0;
    border: none;
    background: none;
    color: rgba(255, 255, 255, 0.9);
    font-family: inherit;
    font-size: 1rem;
    font-weight: 400;
    padding: 10px 8px;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .cs-cancel:active { opacity: 0.5; }

  .cs-hint {
    margin-top: 14px;
    text-align: center;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: 0.04em;
    font-family: inherit;
  }

  .cs-hint kbd {
    font-family: inherit;
    font-size: inherit;
    background: rgba(255, 255, 255, 0.12);
    border-radius: 4px;
    padding: 1px 5px;
  }

  /* Close button — desktop only (mobile uses Cancel) */
  .cs-close {
    position: fixed;
    top: 20px;
    right: 20px;
    z-index: 2;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.75);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    -webkit-tap-highlight-color: transparent;
    transition: background 0.15s, color 0.15s, transform 0.2s cubic-bezier(0.32, 0.72, 0, 1);
  }

  .cs-close:hover {
    background: rgba(255, 255, 255, 0.2);
    color: #fff;
  }

  .cs-close:active { transform: scale(0.92); }

  @media (hover: none) and (pointer: coarse) {
    .cs-cancel { display: block; }
    .cs-close, .cs-hint { display: none; }
    .cs-center { margin-top: calc(16px + env(safe-area-inset-top, 0px)); }
  }
</style>

<script>
  (function () {
    const overlay    = document.getElementById('cs-overlay');
    const input      = document.getElementById('cs-input');
    const backdrop   = document.getElementById('cs-backdrop');
    const closeBtn   = document.getElementById('cs-close');
    const cancelBtn  = document.getElementById('cs-cancel');
    const form       = document.getElementById('cs-form');
    const field      = form.querySelector('.cs-field');
    const promptsEl  = document.getElementById('cs-prompts');
    const promptText = document.getElementById('cs-prompt-text');

    const prompts = ['mercurial vapor', 'f50', 'nike tiempo', 'fg studs'];
    let promptIdx = 0;
    let promptTimer = null;

    function cyclePrompt() {
      promptsEl.classList.add('cs-prompt-fade');
      setTimeout(function () {
        promptIdx = (promptIdx + 1) % prompts.length;
        promptText.textContent = prompts[promptIdx];
        promptsEl.classList.remove('cs-prompt-fade');
      }, 300);
    }

    /* Always clear before starting so timers can never stack
       (stacked intervals were the source of the flickering prompts) */
    function startPrompts() {
      stopPrompts();
      promptIdx = 0;
      promptText.textContent = prompts[0];
      promptsEl.classList.remove('cs-prompt-fade', 'cs-prompt-hidden');
      promptTimer = setInterval(cyclePrompt, 2400);
    }

    function stopPrompts() {
      if (promptTimer) { clearInterval(promptTimer); promptTimer = null; }
    }

    function syncQueryState() {
      const hasQuery = input.value.length > 0;
      field.classList.toggle('cs-has-query', hasQuery);
      if (hasQuery) {
        promptsEl.classList.add('cs-prompt-hidden');
        stopPrompts();
      } else if (!promptTimer) {
        startPrompts();
      }
    }

    input.addEventListener('input', syncQueryState);

    function openSearch() {
      if (overlay.classList.contains('cs-open')) return;
      overlay.classList.add('cs-open');
      overlay.setAttribute('aria-hidden', 'false');
      input.value = '';
      syncQueryState();
      startPrompts();
      /* focus synchronously inside the tap gesture so the iOS
         keyboard opens; preventScroll stops the viewport jump */
      try { input.focus({ preventScroll: true }); }
      catch (e) { input.focus(); }
    }

    function closeSearch() {
      overlay.classList.remove('cs-open');
      overlay.setAttribute('aria-hidden', 'true');
      input.blur();
      input.value = '';
      field.classList.remove('cs-has-query');
      stopPrompts();
    }

    backdrop.addEventListener('click', closeSearch);
    closeBtn.addEventListener('click', closeSearch);
    cancelBtn.addEventListener('click', closeSearch);

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && overlay.classList.contains('cs-open')) {
        closeSearch();
      }
    });

    form.addEventListener('submit', function (e) {
      var q = input.value.trim();
      if (!q) { e.preventDefault(); return; }
      /* Append a wildcard so Shopify prefix-matches the last term:
         "pred" finds "predator". Skip if the user already used one
         or is quoting an exact phrase. */
      if (!/[*"]$/.test(q)) input.value = q + '*';
    });

    window.customSearchOpen  = openSearch;
    window.customSearchClose = closeSearch;
  })();
</script>
