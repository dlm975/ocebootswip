{% doc %}
  @prompt
    a testimonial section. 3 rows of testimonial cards. the cards are long rounded rectangle capsules with a circular pic, name and description. that should slide horizontally across the screen as the user scrolls to give an interactive feeling. each testimonial will be editable,  the padding between rows should be small. there should be 5 cards of testimonials per row. these rows should slide as the user scrolls down the screen, not automatically., the first row should begin with testimonial 2 in the center of screen. the second row should begin with testimonial 4 in the center of screen. the first row should begin with testimonial 2 in the center of screen. the background color should span the full width of screen., the section should fit tightly to the left side of the screen without any white space.  there should be no horizontal scrollability as the cards should slide themselves into view, disregard the tight to left comment. the section should be centered and cover full screen frame width, with no white/ dead space on either side, provide a setting to adjust section width and positioning
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonials-wrapper-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-testimonials-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.section_width }}%;
    {% if block.settings.section_alignment == 'left' %}
      margin-left: 0;
      margin-right: auto;
    {% elsif block.settings.section_alignment == 'right' %}
      margin-left: auto;
      margin-right: 0;
    {% else %}
      margin-left: auto;
      margin-right: auto;
    {% endif %}
    overflow: hidden;
  }

  .ai-testimonials-row-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap_between_cards }}px;
    margin-bottom: {{ block.settings.gap_between_rows }}px;
    will-change: transform;
  }

  .ai-testimonials-row-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-testimonial-card-{{ ai_gen_id }} {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 16px;
    padding: {{ block.settings.card_padding }}px {{ block.settings.card_padding | times: 1.5 }}px;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    min-width: {{ block.settings.card_min_width }}px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-testimonial-image-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.image_size }}px;
    height: {{ block.settings.image_size }}px;
    border-radius: 50%;
    overflow: hidden;
    background-color: #f0f0f0;
  }

  .ai-testimonial-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-testimonial-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #e0e0e0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-testimonial-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-testimonial-content-{{ ai_gen_id }} {
    flex-grow: 1;
    min-width: 0;
  }

  .ai-testimonial-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.name_font_size }}px;
    font-weight: 600;
    color: {{ block.settings.name_color }};
    margin: 0 0 4px 0;
  }

  .ai-testimonial-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-testimonials-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-testimonial-card-{{ ai_gen_id }} {
      min-width: {{ block.settings.card_min_width | times: 0.8 }}px;
    }

    .ai-testimonial-image-{{ ai_gen_id }} {
      width: {{ block.settings.image_size | times: 0.8 }}px;
      height: {{ block.settings.image_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-testimonials-wrapper-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <testimonials-slider-{{ ai_gen_id }}
    class="ai-testimonials-{{ ai_gen_id }}"
    data-scroll-speed="{{ block.settings.scroll_speed }}"
  >
    {% for row_num in (1..3) %}
      <div class="ai-testimonials-row-{{ ai_gen_id }}" data-row="{{ row_num }}">
        {% for card_num in (1..5) %}
          {% liquid
            assign testimonial_index = row_num | minus: 1 | times: 5 | plus: card_num
            assign image_key = 'testimonial_' | append: testimonial_index | append: '_image'
            assign name_key = 'testimonial_' | append: testimonial_index | append: '_name'
            assign description_key = 'testimonial_' | append: testimonial_index | append: '_description'

            assign testimonial_image = block.settings[image_key]
            assign testimonial_name = block.settings[name_key]
            assign testimonial_description = block.settings[description_key]
          %}

          <div class="ai-testimonial-card-{{ ai_gen_id }}">
            <div class="ai-testimonial-image-{{ ai_gen_id }}">
              {% if testimonial_image %}
                <img
                  src="{{ testimonial_image | image_url: width: 200 }}"
                  alt="{{ testimonial_name | escape }}"
                  loading="lazy"
                  width="200"
                  height="200"
                >
              {% else %}
                <div class="ai-testimonial-image-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            <div class="ai-testimonial-content-{{ ai_gen_id }}">
              {% if testimonial_name != blank %}
                <h3 class="ai-testimonial-name-{{ ai_gen_id }}">{{ testimonial_name }}</h3>
              {% else %}
                <h3 class="ai-testimonial-name-{{ ai_gen_id }}">Customer {{ testimonial_index }}</h3>
              {% endif %}
              {% if testimonial_description != blank %}
                <p class="ai-testimonial-description-{{ ai_gen_id }}">{{ testimonial_description }}</p>
              {% else %}
                <p class="ai-testimonial-description-{{ ai_gen_id }}">Add a testimonial description</p>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endfor %}
  </testimonials-slider-{{ ai_gen_id }}>
</div>

<script>
  (function() {
    class TestimonialsSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.rows = this.querySelectorAll('.ai-testimonials-row-{{ ai_gen_id }}');
        this.scrollSpeed = parseFloat(this.dataset.scrollSpeed) || 0.5;
        this.lastScrollY = window.scrollY;
        this.rowOffsets = [0, 0, 0];
        this.isInitialized = false;
      }

      connectedCallback() {
        this.initializeRows();
        this.handleScroll = this.handleScroll.bind(this);
        window.addEventListener('scroll', this.handleScroll, { passive: true });
        this.handleScroll();
      }

      disconnectedCallback() {
        window.removeEventListener('scroll', this.handleScroll);
      }

      initializeRows() {
        this.rows.forEach((row, index) => {
          const rowNum = parseInt(row.dataset.row);
          let initialOffset = 0;

          if (rowNum === 1) {
            const cardWidth = row.querySelector('.ai-testimonial-card-{{ ai_gen_id }}').offsetWidth;
            const gap = {{ block.settings.gap_between_cards }};
            initialOffset = -(cardWidth + gap);
          } else if (rowNum === 2) {
            const cardWidth = row.querySelector('.ai-testimonial-card-{{ ai_gen_id }}').offsetWidth;
            const gap = {{ block.settings.gap_between_cards }};
            initialOffset = -(cardWidth + gap) * 3;
          } else if (rowNum === 3) {
            const cardWidth = row.querySelector('.ai-testimonial-card-{{ ai_gen_id }}').offsetWidth;
            const gap = {{ block.settings.gap_between_cards }};
            initialOffset = -(cardWidth + gap);
          }

          this.rowOffsets[index] = initialOffset;
          row.style.transform = `translateX(${initialOffset}px)`;
        });

        this.isInitialized = true;
      }

      handleScroll() {
        const currentScrollY = window.scrollY;
        const scrollDelta = currentScrollY - this.lastScrollY;

        this.rows.forEach((row, index) => {
          const rowNum = parseInt(row.dataset.row);
          let direction = 1;

          if (rowNum === 2) {
            direction = -1;
          }

          this.rowOffsets[index] += scrollDelta * this.scrollSpeed * direction;

          row.style.transform = `translateX(${this.rowOffsets[index]}px)`;
        });

        this.lastScrollY = currentScrollY;
      }
    }

    customElements.define('testimonials-slider-{{ ai_gen_id }}', TestimonialsSlider{{ ai_gen_id }});
  })();
</script>

