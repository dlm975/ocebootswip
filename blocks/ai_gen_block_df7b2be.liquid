{% doc %}
  @prompt
    Create a sticky navigation bar that stays fixed at the bottom of the page at all times. The bar should be a long horizontal rectangle with heavily rounded edges (large border radius). Add a prominent shadow effect to create a 3D appearance that makes it appear to float above the page. The navigation bar should contain customizable menu links and remain visible even when scrolling. Use a solid background color that contrasts with the shadow., Create an opacity slider for this. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-sticky-nav-{{ ai_gen_id }} {
    display: block;
    position: fixed;
    bottom: {{ block.settings.bottom_spacing }}px;
    left: 50%;
    transform: translateX(-50%);
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: {{ block.settings.max_width }}px;
    z-index: 1000;
    padding: 0 20px;
    opacity: {{ block.settings.opacity }};
  }

  .ai-sticky-nav__container-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    box-shadow: 
      0 {{ block.settings.shadow_offset_y }}px {{ block.settings.shadow_blur }}px {{ block.settings.shadow_spread }}px {{ block.settings.shadow_color }},
      0 {{ block.settings.shadow_offset_y | times: 0.5 }}px {{ block.settings.shadow_blur | times: 0.5 }}px {{ block.settings.shadow_spread | times: 0.5 }}px {{ block.settings.shadow_color }};
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: {{ block.settings.link_spacing }}px;
  }

  .ai-sticky-nav__link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    text-decoration: none;
    font-size: {{ block.settings.link_font_size }}px;
    font-weight: {{ block.settings.link_font_weight }};
    padding: {{ block.settings.link_padding_vertical }}px {{ block.settings.link_padding_horizontal }}px;
    border-radius: {{ block.settings.link_border_radius }}px;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .ai-sticky-nav__link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
    background-color: {{ block.settings.link_hover_background }};
  }

  @media screen and (max-width: 749px) {
    .ai-sticky-nav-{{ ai_gen_id }} {
      width: calc(100% - 40px);
      padding: 0 20px;
    }

    .ai-sticky-nav__container-{{ ai_gen_id }} {
      gap: {{ block.settings.link_spacing | times: 0.5 }}px;
      padding: {{ block.settings.padding_vertical | times: 0.8 }}px {{ block.settings.padding_horizontal | times: 0.8 }}px;
    }

    .ai-sticky-nav__link-{{ ai_gen_id }} {
      font-size: {{ block.settings.link_font_size | times: 0.9 }}px;
      padding: {{ block.settings.link_padding_vertical | times: 0.8 }}px {{ block.settings.link_padding_horizontal | times: 0.8 }}px;
    }
  }
{% endstyle %}

<sticky-bottom-nav-{{ ai_gen_id }} class="ai-sticky-nav-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <nav class="ai-sticky-nav__container-{{ ai_gen_id }}" role="navigation" aria-label="Bottom navigation">
    {% for i in (1..6) %}
      {% liquid
        assign link_text_key = 'link_' | append: i | append: '_text'
        assign link_url_key = 'link_' | append: i | append: '_url'
        assign link_text = block.settings[link_text_key]
        assign link_url = block.settings[link_url_key]
      %}
      
      {% if link_text != blank %}
        <a href="{{ link_url }}" class="ai-sticky-nav__link-{{ ai_gen_id }}">
          {{ link_text }}
        </a>
      {% endif %}
    {% endfor %}
  </nav>
</sticky-bottom-nav-{{ ai_gen_id }}>

<script>
  (function() {
    class StickyBottomNav{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const links = this.querySelectorAll('.ai-sticky-nav__link-{{ ai_gen_id }}');
        links.forEach((link, index) => {
          if (!link.getAttribute('aria-label')) {
            link.setAttribute('aria-label', link.textContent.trim());
          }
        });
      }
    }

    customElements.define('sticky-bottom-nav-{{ ai_gen_id }}', StickyBottomNav{{ ai_gen_id }});
  })();
</script>

