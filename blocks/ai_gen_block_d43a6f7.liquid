      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f5f5f5"
    },
    {
      "type": "header",
      "content": "Scroll settings"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "label": "Auto scroll speed",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "default": 1
    },
    {
      "type": "header",
      "content": "Product image"
    },
    {
      "type": "range",
      "id": "image_height",
      "label": "Image height",
      "min": 100,
      "max": 600,
      "step": 10,
      "unit": "px",
      "default": 300
    },
    {
      "type": "header",
      "content": "Product information"
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show price",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_variant",
      "label": "Show variant",
      "default": true
    },
    {
      "type": "text",
      "id": "variant_option_name",
      "label": "Variant option name",
      "default": "Size"
    },
    {
