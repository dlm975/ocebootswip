{% doc %}
  @prompt
    a featured collection section. holographic product cards. this will be where we feature the new arrivals. i want 3 product cards wide on mobile, 6 wide on desktop., make the product cards 3D. , allow a customisable gradient background, Allow heading font customization
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-featured-collection-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    {% if block.settings.use_gradient %}
      background: linear-gradient({{ block.settings.gradient_angle }}deg, 
        {{ block.settings.gradient_color_1 }} 0%, 
        {{ block.settings.gradient_color_2 }} 100%);
    {% else %}
      background-color: {{ block.settings.background_color }};
    {% endif %}
    perspective: 1000px;
  }

  .ai-featured-collection__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-featured-collection__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: 40px;
  }

  .ai-featured-collection__title-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
  }

  .ai-featured-collection__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
  }

  .ai-featured-collection__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  @media screen and (min-width: 750px) {
    .ai-featured-collection__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(6, 1fr);
    }
  }

  .ai-featured-collection__card-{{ ai_gen_id }} {
    position: relative;
    border-radius: {{ block.settings.card_border_radius }}px;
    background: linear-gradient(135deg, 
      {{ block.settings.holographic_color_1 }} 0%, 
      {{ block.settings.holographic_color_2 }} 25%, 
      {{ block.settings.holographic_color_3 }} 50%, 
      {{ block.settings.holographic_color_4 }} 75%, 
      {{ block.settings.holographic_color_1 }} 100%);
    background-size: 200% 200%;
    animation: ai-holographic-shift-{{ ai_gen_id }} 3s ease infinite;
    padding: 2px;
    transform-style: preserve-3d;
    transition: transform 0.6s ease;
  }

  .ai-featured-collection__card-{{ ai_gen_id }}:hover {
    transform: rotateY({{ block.settings.rotate_y }}deg) rotateX({{ block.settings.rotate_x }}deg) translateZ({{ block.settings.translate_z }}px);
  }

  @keyframes ai-holographic-shift-{{ ai_gen_id }} {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  .ai-featured-collection__card-inner-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: calc({{ block.settings.card_border_radius }}px - 2px);
    overflow: hidden;
    height: 100%;
    display: flex;
    flex-direction: column;
    transform-style: preserve-3d;
    box-shadow: 0 {{ block.settings.shadow_depth }}px {{ block.settings.shadow_blur }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity }});
  }

  .ai-featured-collection__card-{{ ai_gen_id }}:hover .ai-featured-collection__card-inner-{{ ai_gen_id }} {
    box-shadow: 0 {{ block.settings.shadow_depth | times: 2 }}px {{ block.settings.shadow_blur | times: 2 }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity | times: 1.5 }});
  }

  .ai-featured-collection__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .ai-featured-collection__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .ai-featured-collection__card-{{ ai_gen_id }}:hover .ai-featured-collection__image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-featured-collection__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-featured-collection__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-featured-collection__info-{{ ai_gen_id }} {
    padding: 12px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
    transform: translateZ(20px);
  }

  .ai-featured-collection__product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    color: {{ block.settings.product_title_color }};
    margin: 0;
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .ai-featured-collection__product-title-{{ ai_gen_id }} a {
    color: inherit;
    text-decoration: none;
  }

  .ai-featured-collection__product-title-{{ ai_gen_id }} a:hover {
    opacity: 0.8;
  }

  .ai-featured-collection__price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 600;
  }

  .ai-featured-collection__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
  }

  .ai-featured-collection__empty-state-{{ ai_gen_id }} p {
    margin: 0;
    font-size: 16px;
  }

  .ai-featured-collection__view-all-{{ ai_gen_id }} {
    text-align: center;
    margin-top: 40px;
  }

  .ai-featured-collection__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 500;
    transition: all 0.3s ease;
  }

  .ai-featured-collection__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-featured-collection__card-{{ ai_gen_id }} {
      animation: none;
    }
    .ai-featured-collection__card-{{ ai_gen_id }}:hover {
      transform: translateY(-4px);
    }
  }
{% endstyle %}

<featured-collection-{{ ai_gen_id }}
  class="ai-featured-collection-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-featured-collection__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.description != blank %}
      <div class="ai-featured-collection__header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-featured-collection__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.description != blank %}
          <div class="ai-featured-collection__description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.collection != blank %}
      <div class="ai-featured-collection__grid-{{ ai_gen_id }}">
        {% for product in block.settings.collection.products limit: block.settings.products_to_show %}
          <div class="ai-featured-collection__card-{{ ai_gen_id }}" data-card-index="{{ forloop.index }}">
            <div class="ai-featured-collection__card-inner-{{ ai_gen_id }}">
              <div class="ai-featured-collection__image-wrapper-{{ ai_gen_id }}">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 400 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    class="ai-featured-collection__image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="400"
                    height="400"
                  >
                {% else %}
                  <div class="ai-featured-collection__image-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>
              <div class="ai-featured-collection__info-{{ ai_gen_id }}">
                <h3 class="ai-featured-collection__product-title-{{ ai_gen_id }}">
                  <a href="{{ product.url }}">{{ product.title }}</a>
                </h3>
                <div class="ai-featured-collection__price-{{ ai_gen_id }}">
                  {{ product.price | money }}
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>

      {% if block.settings.show_view_all %}
        <div class="ai-featured-collection__view-all-{{ ai_gen_id }}">
          <a href="{{ block.settings.collection.url }}" class="ai-featured-collection__button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </a>
        </div>
      {% endif %}
    {% else %}
      <div class="ai-featured-collection__empty-state-{{ ai_gen_id }}">
        <p>Next, select a collection to feature your new arrivals</p>
      </div>
    {% endif %}
  </div>
</featured-collection-{{ ai_gen_id }}>

<script>
  (function() {
    class FeaturedCollection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.initializeCards();
      }

      initializeCards() {
        const cards = this.querySelectorAll('.ai-featured-collection__card-{{ ai_gen_id }}');
        
        cards.forEach(card => {
          card.addEventListener('mouseenter', () => {
            card.style.animationPlayState = 'paused';
          });
          
          card.addEventListener('mouseleave', () => {
            card.style.animationPlayState = 'running';
          });

          card.addEventListener('mousemove', (e) => {
            if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
              return;
            }

            const rect = card.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            
            const centerX = rect.width / 2;
            const centerY = rect.height / 2;
            
            const rotateX = ((y - centerY) / centerY) * {{ block.settings.tilt_intensity }};
            const rotateY = ((x - centerX) / centerX) * {{ block.settings.tilt_intensity }};
            
            card.style.transform = `rotateX(${-rotateX}deg) rotateY(${rotateY}deg) translateZ({{ block.settings.translate_z }}px)`;
          });

          card.addEventListener('mouseleave', () => {
            card.style.transform = '';
          });
        });
      }
    }

    customElements.define('featured-collection-{{ ai_gen_id }}', FeaturedCollection{{ ai_gen_id }});
  })();
</script>

