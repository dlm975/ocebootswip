<div
  class="pdp-trust-bar"
  style="{% render 'spacing-style', settings: block.settings %}"
  {{ block.shopify_attributes }}
>

  <!-- Item 1 -->
  <div class="pdp-trust-item">
    <span class="pdp-trust-item__icon" aria-hidden="true">
      {%- if block.settings.icon_1 != blank -%}
        {{ block.settings.icon_1 | image_url: width: 80 | image_tag: width: 28, height: 28, style: 'object-fit: contain; width: 28px; height: 28px;' }}
      {%- else -%}
        <svg viewBox="0 0 24 24" width="24" height="24"><circle cx="12" cy="12" r="12" fill="#ccc"/></svg>
      {%- endif -%}
    </span>
    <span class="pdp-trust-item__text">{{ block.settings.text_1 }}</span>
  </div>

  <div class="pdp-trust-divider" aria-hidden="true"></div>

  <!-- Item 2 -->
  <div class="pdp-trust-item">
    <span class="pdp-trust-item__icon" aria-hidden="true">
      {%- if block.settings.icon_2 != blank -%}
        {{ block.settings.icon_2 | image_url: width: 80 | image_tag: width: 28, height: 28, style: 'object-fit: contain; width: 28px; height: 28px;' }}
      {%- else -%}
        <svg viewBox="0 0 24 24" width="24" height="24"><circle cx="12" cy="12" r="12" fill="#ccc"/></svg>
      {%- endif -%}
    </span>
    <span class="pdp-trust-item__text">{{ block.settings.text_2 }}</span>
  </div>

  <div class="pdp-trust-divider" aria-hidden="true"></div>

  <!-- Item 3 -->
  <div class="pdp-trust-item">
    <span class="pdp-trust-item__icon" aria-hidden="true">
      {%- if block.settings.icon_3 != blank -%}
        {{ block.settings.icon_3 | image_url: width: 80 | image_tag: width: 28, height: 28, style: 'object-fit: contain; width: 28px; height: 28px;' }}
      {%- else -%}
        <svg viewBox="0 0 24 24" width="24" height="24"><circle cx="12" cy="12" r="12" fill="#ccc"/></svg>
      {%- endif -%}
    </span>
    <span class="pdp-trust-item__text">{{ block.settings.text_3 }}</span>
  </div>

</div>

<style>
  .pdp-trust-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    background: #f8f8f8;
    border-radius: 10px;
    width: 100%;
    box-sizing: border-box;
    gap: 8px;
  }

  .pdp-trust-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    text-align: center;
    flex: 1;
  }

  .pdp-trust-item__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
  }

  .pdp-trust-item__icon img {
    width: 28px;
    height: 28px;
    object-fit: contain;
  }

  .pdp-trust-item__text {
    font-size: 0.7rem;
    font-weight: 600;
    color: #333;
    line-height: 1.2;
  }

  .pdp-trust-divider {
    width: 1px;
    height: 34px;
    background: #dedede;
    flex-shrink: 0;
  }
</style>

{% schema %}
{
  "name": "Trust Bar",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Item 1"
    },
    {
      "type": "image_picker",
      "id": "icon_1",
      "label": "Icon"
    },
    {
      "type": "text",
      "id": "text_1",
      "label": "Text",
      "default": "Verified Boots"
    },
    {
      "type": "header",
      "content": "Item 2"
    },
    {
      "type": "image_picker",
      "id": "icon_2",
      "label": "Icon"
    },
    {
      "type": "text",
      "id": "text_2",
      "label": "Text",
      "default": "Express Shipping"
    },
    {
      "type": "header",
      "content": "Item 3"
    },
    {
      "type": "image_picker",
      "id": "icon_3",
      "label": "Icon"
    },
    {
      "type": "text",
      "id": "text_3",
      "label": "Text",
      "default": "Accept Returns"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0, "max": 100, "step": 1, "unit": "px", "default": 8
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "Left",
      "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "Right",
      "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0
    }
  ],
  "presets": [
    {
      "name": "Trust Bar",
      "category": "Product"
    }
  ]
}
{% endschema %}
