<div
  class="pdp-trust-bar"
  style="{% render 'spacing-style', settings: block.settings %}"
  {{ block.shopify_attributes }}
>

  <!-- Verified Boots -->
  <div class="pdp-trust-item">
    <span class="pdp-trust-item__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="22" height="22" xmlns="http://www.w3.org/2000/svg">
        <circle cx="12" cy="12" r="12" fill="#1d9bf0"/>
        <path d="M6.5 12.5l3.5 3.5 7-7" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      </svg>
    </span>
    <span class="pdp-trust-item__text">{{ block.settings.text_1 }}</span>
  </div>

  <div class="pdp-trust-divider" aria-hidden="true"></div>

  <!-- Express Shipping -->
  <div class="pdp-trust-item">
    <span class="pdp-trust-item__icon" aria-hidden="true">
      <svg viewBox="0 0 28 20" width="30" height="20" xmlns="http://www.w3.org/2000/svg">
        <!-- Plane body -->
        <path d="M2 10L14 2l10 4-5 2 3 5-6-1-3 4-3-5-8-1z" fill="#FFCC00"/>
        <!-- DHL red accent stripe -->
        <path d="M14 6l4 1.5-2 3.5-5-1z" fill="#EE2320"/>
        <!-- Tail fin -->
        <path d="M2 10l4 1-2 4-5-3z" fill="#EE2320"/>
      </svg>
    </span>
    <span class="pdp-trust-item__text">{{ block.settings.text_2 }}</span>
  </div>

  <div class="pdp-trust-divider" aria-hidden="true"></div>

  <!-- Accept Returns -->
  <div class="pdp-trust-item">
    <span class="pdp-trust-item__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- Circular arrows (recycle) -->
        <path d="M12 4a8 8 0 0 1 6.93 4H16l3 4 3-4h-2.27A10 10 0 1 0 22 12h-2a8 8 0 1 1-8-8z" fill="#38a169"/>
        <path d="M8 10l-3 4 3 4" stroke="#38a169" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      </svg>
    </span>
    <span class="pdp-trust-item__text">{{ block.settings.text_3 }}</span>
  </div>

</div>

<style>
  .pdp-trust-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    background: #f8f8f8;
    border-radius: 10px;
    width: 100%;
    box-sizing: border-box;
    gap: 8px;
  }

  .pdp-trust-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    text-align: center;
    flex: 1;
  }

  .pdp-trust-item__icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pdp-trust-item__text {
    font-size: 0.7rem;
    font-weight: 600;
    color: #333;
    line-height: 1.2;
  }

  .pdp-trust-divider {
    width: 1px;
    height: 34px;
    background: #dedede;
    flex-shrink: 0;
  }
</style>

{% schema %}
{
  "name": "Trust Bar",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "text_1",
      "label": "Item 1 text",
      "default": "Verified Boots"
    },
    {
      "type": "text",
      "id": "text_2",
      "label": "Item 2 text",
      "default": "Express Shipping"
    },
    {
      "type": "text",
      "id": "text_3",
      "label": "Item 3 text",
      "default": "Accept Returns"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0, "max": 100, "step": 1, "unit": "px", "default": 8
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "Left",
      "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "Right",
      "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0
    }
  ],
  "presets": [
    {
      "name": "Trust Bar",
      "category": "Product"
    }
  ]
}
{% endschema %}
