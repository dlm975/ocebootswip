{% doc %}
  @prompt
    Create a sticky navigation bar that stays fixed at the bottom of the page at all times. The bar should be a long horizontal rectangle with heavily rounded edges (large border radius). Add a prominent shadow effect to create a 3D appearance that makes it appear to float above the page. The navigation bar should contain customizable menu links and remain visible even when scrolling. Use a glass like texture for the background . Create an opacity slider for this. Ideally the content in the bar will be "Shop By Size" that when clicked, the bar will then present with 3 options: US Size, UK Size, EU Size. When the size type options is clicked, a list will expanded onto the screen with the range of size options, each linked to a collection in my store, Make sure that behaviourally it is "at FRONT" at all times, with no other elements hovering above. Provide ability to change main button text and size type label font. Also make the "Shop By Size" text disappear on the size type label screen.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-sticky-nav-{{ ai_gen_id }} {
    position: fixed;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 99999;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 90vw;
    display: block;
  }

  .ai-sticky-nav-container-{{ ai_gen_id }} {
    background: {{ block.settings.background_color }};
    backdrop-filter: blur({{ block.settings.blur_amount }}px);
    -webkit-backdrop-filter: blur({{ block.settings.blur_amount }}px);
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.padding }}px {{ block.settings.padding | times: 1.5 }}px;
    box-shadow: 0 {{ block.settings.shadow_offset }}px {{ block.settings.shadow_blur }}px {{ block.settings.shadow_spread }}px {{ block.settings.shadow_color }};
    opacity: {{ block.settings.opacity | divided_by: 100.0 }};
    transition: all 0.3s ease;
  }

  .ai-sticky-nav-main-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
  }

  .ai-sticky-nav-trigger-{{ ai_gen_id }} {
    background: none;
    border: none;
    color: {{ block.settings.text_color }};
    font-family: {{ block.settings.main_button_font.family }}, {{ block.settings.main_button_font.fallback_families }};
    font-weight: {{ block.settings.main_button_font.weight }};
    font-style: {{ block.settings.main_button_font.style }};
    font-size: {{ block.settings.font_size }}px;
    cursor: pointer;
    padding: 8px 16px;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: opacity 0.3s ease;
  }

  .ai-sticky-nav-trigger-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-sticky-nav-trigger-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
    transition: transform 0.3s ease;
  }

  .ai-sticky-nav-trigger-{{ ai_gen_id }}.active svg {
    transform: rotate(180deg);
  }

  .ai-sticky-nav-trigger-{{ ai_gen_id }}.hidden {
    display: none;
  }

  .ai-sticky-nav-options-{{ ai_gen_id }} {
    display: none;
    gap: 12px;
  }

  .ai-sticky-nav-options-{{ ai_gen_id }}.active {
    display: flex;
  }

  .ai-sticky-nav-option-btn-{{ ai_gen_id }} {
    background: {{ block.settings.option_bg_color }};
    color: {{ block.settings.option_text_color }};
    font-family: {{ block.settings.size_type_font.family }}, {{ block.settings.size_type_font.fallback_families }};
    font-weight: {{ block.settings.size_type_font.weight }};
    font-style: {{ block.settings.size_type_font.style }};
    border: 1px solid {{ block.settings.option_border_color }};
    border-radius: {{ block.settings.option_border_radius }}px;
    padding: 8px 20px;
    font-size: {{ block.settings.option_font_size }}px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-sticky-nav-option-btn-{{ ai_gen_id }}:hover {
    background: {{ block.settings.option_hover_bg_color }};
    color: {{ block.settings.option_hover_text_color }};
  }

  .ai-sticky-nav-sizes-{{ ai_gen_id }} {
    position: fixed;
    bottom: 120px;
    left: 50%;
    transform: translateX(-50%);
    background: {{ block.settings.background_color }};
    backdrop-filter: blur({{ block.settings.blur_amount }}px);
    -webkit-backdrop-filter: blur({{ block.settings.blur_amount }}px);
    border-radius: {{ block.settings.border_radius }}px;
    padding: 20px;
    box-shadow: 0 {{ block.settings.shadow_offset }}px {{ block.settings.shadow_blur }}px {{ block.settings.shadow_spread }}px {{ block.settings.shadow_color }};
    opacity: {{ block.settings.opacity | divided_by: 100.0 }};
    max-height: 400px;
    overflow-y: auto;
    display: none;
    z-index: 99998;
    min-width: 200px;
  }

  .ai-sticky-nav-sizes-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-sticky-nav-sizes-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid {{ block.settings.option_border_color }};
  }

  .ai-sticky-nav-sizes-title-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-family: {{ block.settings.size_type_font.family }}, {{ block.settings.size_type_font.fallback_families }};
    font-weight: {{ block.settings.size_type_font.weight }};
    font-style: {{ block.settings.size_type_font.style }};
    font-size: {{ block.settings.font_size }}px;
    margin: 0;
  }

  .ai-sticky-nav-close-{{ ai_gen_id }} {
    background: none;
    border: none;
    color: {{ block.settings.text_color }};
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-sticky-nav-close-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  .ai-sticky-nav-size-list-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-sticky-nav-size-link-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    text-decoration: none;
    padding: 10px 16px;
    border-radius: {{ block.settings.option_border_radius }}px;
    background: {{ block.settings.option_bg_color }};
    border: 1px solid {{ block.settings.option_border_color }};
    transition: all 0.3s ease;
    text-align: center;
    font-size: {{ block.settings.option_font_size }}px;
  }

  .ai-sticky-nav-size-link-{{ ai_gen_id }}:hover {
    background: {{ block.settings.option_hover_bg_color }};
    color: {{ block.settings.option_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-sticky-nav-{{ ai_gen_id }} {
      width: 90%;
      bottom: 10px;
    }

    .ai-sticky-nav-container-{{ ai_gen_id }} {
      padding: {{ block.settings.padding | times: 0.8 }}px {{ block.settings.padding | times: 1.2 }}px;
    }

    .ai-sticky-nav-trigger-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
      padding: 6px 12px;
    }

    .ai-sticky-nav-option-btn-{{ ai_gen_id }} {
      font-size: {{ block.settings.option_font_size | times: 0.9 }}px;
      padding: 6px 16px;
    }

    .ai-sticky-nav-sizes-{{ ai_gen_id }} {
      bottom: 90px;
      width: 80%;
      max-width: 300px;
    }
  }
{% endstyle %}

<sticky-size-nav-{{ ai_gen_id }}
  class="ai-sticky-nav-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-sticky-nav-container-{{ ai_gen_id }}">
    <div class="ai-sticky-nav-main-{{ ai_gen_id }}">
      <button
        class="ai-sticky-nav-trigger-{{ ai_gen_id }}"
        aria-label="Shop by size"
        aria-expanded="false"
      >
        {{ block.settings.main_text }}
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </button>

      <div class="ai-sticky-nav-options-{{ ai_gen_id }}">
        <button
          class="ai-sticky-nav-option-btn-{{ ai_gen_id }}"
          data-size-type="us"
        >
          {{ block.settings.us_label }}
        </button>
        <button
          class="ai-sticky-nav-option-btn-{{ ai_gen_id }}"
          data-size-type="uk"
        >
          {{ block.settings.uk_label }}
        </button>
        <button
          class="ai-sticky-nav-option-btn-{{ ai_gen_id }}"
          data-size-type="eu"
        >
          {{ block.settings.eu_label }}
        </button>
      </div>
    </div>
  </div>

  <div class="ai-sticky-nav-sizes-{{ ai_gen_id }}">
    <div class="ai-sticky-nav-sizes-header-{{ ai_gen_id }}">
      <h3 class="ai-sticky-nav-sizes-title-{{ ai_gen_id }}"></h3>
      <button
        class="ai-sticky-nav-close-{{ ai_gen_id }}"
        aria-label="Close size list"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div class="ai-sticky-nav-size-list-{{ ai_gen_id }}"></div>
  </div>
</sticky-size-nav-{{ ai_gen_id }}>

<script>
  (function() {
    class StickySizeNav{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.trigger = this.querySelector('.ai-sticky-nav-trigger-{{ ai_gen_id }}');
        this.optionsContainer = this.querySelector('.ai-sticky-nav-options-{{ ai_gen_id }}');
        this.optionButtons = this.querySelectorAll('.ai-sticky-nav-option-btn-{{ ai_gen_id }}');
        this.sizesPanel = this.querySelector('.ai-sticky-nav-sizes-{{ ai_gen_id }}');
        this.sizesList = this.querySelector('.ai-sticky-nav-size-list-{{ ai_gen_id }}');
        this.sizesTitle = this.querySelector('.ai-sticky-nav-sizes-title-{{ ai_gen_id }}');
        this.closeButton = this.querySelector('.ai-sticky-nav-close-{{ ai_gen_id }}');

        this.sizeData = {
          us: [
            {% if block.settings.us_collection_1 != blank %}
              { size: '{{ block.settings.us_size_1 }}', url: '{{ block.settings.us_collection_1.url }}' },
            {% endif %}
            {% if block.settings.us_collection_2 != blank %}
              { size: '{{ block.settings.us_size_2 }}', url: '{{ block.settings.us_collection_2.url }}' },
            {% endif %}
            {% if block.settings.us_collection_3 != blank %}
              { size: '{{ block.settings.us_size_3 }}', url: '{{ block.settings.us_collection_3.url }}' },
            {% endif %}
            {% if block.settings.us_collection_4 != blank %}
              { size: '{{ block.settings.us_size_4 }}', url: '{{ block.settings.us_collection_4.url }}' },
            {% endif %}
            {% if block.settings.us_collection_5 != blank %}
              { size: '{{ block.settings.us_size_5 }}', url: '{{ block.settings.us_collection_5.url }}' },
            {% endif %}
            {% if block.settings.us_collection_6 != blank %}
              { size: '{{ block.settings.us_size_6 }}', url: '{{ block.settings.us_collection_6.url }}' },
            {% endif %}
            {% if block.settings.us_collection_7 != blank %}
              { size: '{{ block.settings.us_size_7 }}', url: '{{ block.settings.us_collection_7.url }}' },
            {% endif %}
            {% if block.settings.us_collection_8 != blank %}
              { size: '{{ block.settings.us_size_8 }}', url: '{{ block.settings.us_collection_8.url }}' },
            {% endif %}
            {% if block.settings.us_collection_9 != blank %}
              { size: '{{ block.settings.us_size_9 }}', url: '{{ block.settings.us_collection_9.url }}' },
            {% endif %}
            {% if block.settings.us_collection_10 != blank %}
              { size: '{{ block.settings.us_size_10 }}', url: '{{ block.settings.us_collection_10.url }}' }
            {% endif %}
          ].filter(item => item.size && item.url),
          uk: [
            {% if block.settings.uk_collection_1 != blank %}
              { size: '{{ block.settings.uk_size_1 }}', url: '{{ block.settings.uk_collection_1.url }}' },
            {% endif %}
            {% if block.settings.uk_collection_2 != blank %}
              { size: '{{ block.settings.uk_size_2 }}', url: '{{ block.settings.uk_collection_2.url }}' },
            {% endif %}
            {% if block.settings.uk_collection_3 != blank %}
              { size: '{{ block.settings.uk_size_3 }}', url: '{{ block.settings.uk_collection_3.url }}' },
            {% endif %}
            {% if block.settings.uk_collection_4 != blank %}
              { size: '{{ block.settings.uk_size_4 }}', url: '{{ block.settings.uk_collection_4.url }}' },
            {% endif %}
            {% if block.settings.uk_collection_5 != blank %}
              { size: '{{ block.settings.uk_size_5 }}', url: '{{ block.settings.uk_collection_5.url }}' },
            {% endif %}
            {% if block.settings.uk_collection_6 != blank %}
              { size: '{{ block.settings.uk_size_6 }}', url: '{{ block.settings.uk_collection_6.url }}' },
            {% endif %}
            {% if block.settings.uk_collection_7 != blank %}
              { size: '{{ block.settings.uk_size_7 }}', url: '{{ block.settings.uk_collection_7.url }}' },
            {% endif %}
            {% if block.settings.uk_collection_8 != blank %}
              { size: '{{ block.settings.uk_size_8 }}', url: '{{ block.settings.uk_collection_8.url }}' },
            {% endif %}
            {% if block.settings.uk_collection_9 != blank %}
              { size: '{{ block.settings.uk_size_9 }}', url: '{{ block.settings.uk_collection_9.url }}' },
            {% endif %}
            {% if block.settings.uk_collection_10 != blank %}
              { size: '{{ block.settings.uk_size_10 }}', url: '{{ block.settings.uk_collection_10.url }}' }
            {% endif %}
          ].filter(item => item.size && item.url),
          eu: [
            {% if block.settings.eu_collection_1 != blank %}
              { size: '{{ block.settings.eu_size_1 }}', url: '{{ block.settings.eu_collection_1.url }}' },
            {% endif %}
            {% if block.settings.eu_collection_2 != blank %}
              { size: '{{ block.settings.eu_size_2 }}', url: '{{ block.settings.eu_collection_2.url }}' },
            {% endif %}
            {% if block.settings.eu_collection_3 != blank %}
              { size: '{{ block.settings.eu_size_3 }}', url: '{{ block.settings.eu_collection_3.url }}' },
            {% endif %}
            {% if block.settings.eu_collection_4 != blank %}
              { size: '{{ block.settings.eu_size_4 }}', url: '{{ block.settings.eu_collection_4.url }}' },
            {% endif %}
            {% if block.settings.eu_collection_5 != blank %}
              { size: '{{ block.settings.eu_size_5 }}', url: '{{ block.settings.eu_collection_5.url }}' },
            {% endif %}
            {% if block.settings.eu_collection_6 != blank %}
              { size: '{{ block.settings.eu_size_6 }}', url: '{{ block.settings.eu_collection_6.url }}' },
            {% endif %}
            {% if block.settings.eu_collection_7 != blank %}
              { size: '{{ block.settings.eu_size_7 }}', url: '{{ block.settings.eu_collection_7.url }}' },
            {% endif %}
            {% if block.settings.eu_collection_8 != blank %}
              { size: '{{ block.settings.eu_size_8 }}', url: '{{ block.settings.eu_collection_8.url }}' },
            {% endif %}
            {% if block.settings.eu_collection_9 != blank %}
              { size: '{{ block.settings.eu_size_9 }}', url: '{{ block.settings.eu_collection_9.url }}' },
            {% endif %}
            {% if block.settings.eu_collection_10 != blank %}
              { size: '{{ block.settings.eu_size_10 }}', url: '{{ block.settings.eu_collection_10.url }}' }
            {% endif %}
          ].filter(item => item.size && item.url)
        };
      }

      connectedCallback() {
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.trigger.addEventListener('click', () => this.toggleOptions());
        
        this.optionButtons.forEach(button => {
          button.addEventListener('click', (e) => {
            const sizeType = e.target.getAttribute('data-size-type');
            this.showSizes(sizeType);
          });
        });

        this.closeButton.addEventListener('click', () => this.closeSizes());

        document.addEventListener('click', (e) => {
          if (!this.contains(e.target)) {
            this.closeAll();
          }
        });
      }

      toggleOptions() {
        const isActive = this.optionsContainer.classList.contains('active');
        
        if (isActive) {
          this.optionsContainer.classList.remove('active');
          this.trigger.classList.remove('active');
          this.trigger.classList.remove('hidden');
          this.trigger.setAttribute('aria-expanded', 'false');
        } else {
          this.optionsContainer.classList.add('active');
          this.trigger.classList.add('active');
          this.trigger.classList.add('hidden');
          this.trigger.setAttribute('aria-expanded', 'true');
          this.closeSizes();
        }
      }

      showSizes(sizeType) {
        const sizes = this.sizeData[sizeType];
        const labels = {
          us: '{{ block.settings.us_label }}',
          uk: '{{ block.settings.uk_label }}',
          eu: '{{ block.settings.eu_label }}'
        };

        this.sizesTitle.textContent = labels[sizeType];
        this.sizesList.innerHTML = '';

        if (sizes.length === 0) {
          this.sizesList.innerHTML = '<p style="color: {{ block.settings.text_color }}; text-align: center; padding: 20px;">No sizes configured</p>';
        } else {
          sizes.forEach(item => {
            const link = document.createElement('a');
            link.href = item.url;
            link.className = 'ai-sticky-nav-size-link-{{ ai_gen_id }}';
            link.textContent = item.size;
            this.sizesList.appendChild(link);
          });
        }

        this.sizesPanel.classList.add('active');
        this.optionsContainer.classList.remove('active');
        this.trigger.classList.remove('active');
        this.trigger.classList.remove('hidden');
        this.trigger.setAttribute('aria-expanded', 'false');
      }

      closeSizes() {
        this.sizesPanel.classList.remove('active');
      }

      closeAll() {
        this.optionsContainer.classList.remove('active');
        this.trigger.classList.remove('active');
        this.trigger.classList.remove('hidden');
        this.trigger.setAttribute('aria-expanded', 'false');
        this.closeSizes();
      }
    }

    customElements.define('sticky-size-nav-{{ ai_gen_id }}', StickySizeNav{{ ai_gen_id }});
  })();
</script>

