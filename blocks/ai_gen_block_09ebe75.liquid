{% doc %}
  @prompt
    a featured collection section. holographic product cards. this will be where we feature the new arrivals. i want 3 product cards wide on mobile, 6 wide on desktop., make the product cards 3D. , allow a customisable gradient background, Allow heading font customization. Currency must be displayed on the card.
    
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-featured-collection-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    background: linear-gradient(
      {{ block.settings.gradient_angle }}deg,
      {{ block.settings.gradient_color_1 }},
      {{ block.settings.gradient_color_2 }}
    );
  }

  .ai-featured-collection__container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-featured-collection__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: 40px;
  }

  .ai-featured-collection__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    text-transform: {{ block.settings.heading_text_transform }};
  }

  .ai-featured-collection__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.card_gap }}px;
  }

  @media (min-width: 750px) {
    .ai-featured-collection__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(6, 1fr);
    }
  }

  .ai-featured-collection__card-{{ ai_gen_id }} {
    position: relative;
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transform-style: preserve-3d;
    perspective: 1000px;
    transition: transform 0.3s ease;
  }

  .ai-featured-collection__card-{{ ai_gen_id }}:hover {
    transform: rotateY({{ block.settings.card_rotate_y }}deg) rotateX({{ block.settings.card_rotate_x }}deg) scale(1.05);
  }

  .ai-featured-collection__card-inner-{{ ai_gen_id }} {
    position: relative;
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .ai-featured-collection__card-inner-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: linear-gradient(
      45deg,
      transparent 30%,
      rgba(255, 255, 255, 0.3) 50%,
      transparent 70%
    );
    transform: rotate(45deg);
    transition: all 0.6s ease;
    opacity: 0;
    pointer-events: none;
  }

  .ai-featured-collection__card-{{ ai_gen_id }}:hover .ai-featured-collection__card-inner-{{ ai_gen_id }}::before {
    opacity: 1;
    animation: ai-holographic-shine-{{ ai_gen_id }} 1.5s ease-in-out infinite;
  }

  @keyframes ai-holographic-shine-{{ ai_gen_id }} {
    0% {
      transform: translateX(-100%) translateY(-100%) rotate(45deg);
    }
    100% {
      transform: translateX(100%) translateY(100%) rotate(45deg);
    }
  }

  .ai-featured-collection__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background: {{ block.settings.image_background }};
  }

  .ai-featured-collection__image-wrapper-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(
      135deg,
      rgba(255, 0, 255, 0.2) 0%,
      rgba(0, 255, 255, 0.2) 25%,
      rgba(255, 255, 0, 0.2) 50%,
      rgba(0, 255, 0, 0.2) 75%,
      rgba(255, 0, 255, 0.2) 100%
    );
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    mix-blend-mode: overlay;
  }

  .ai-featured-collection__card-{{ ai_gen_id }}:hover .ai-featured-collection__image-wrapper-{{ ai_gen_id }}::after {
    opacity: {{ block.settings.holographic_intensity }};
  }

  .ai-featured-collection__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-featured-collection__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f4f4f4;
  }

  .ai-featured-collection__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-featured-collection__info-{{ ai_gen_id }} {
    padding: 12px;
    background: {{ block.settings.card_background }};
  }

  .ai-featured-collection__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    font-weight: 600;
    color: {{ block.settings.product_title_color }};
    margin: 0 0 8px;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .ai-featured-collection__price-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_price_size }}px;
    color: {{ block.settings.product_price_color }};
    font-weight: 600;
  }

  .ai-featured-collection__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.heading_color }};
    font-size: 16px;
  }
{% endstyle %}

<featured-collection-{{ ai_gen_id }}
  class="ai-featured-collection-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-featured-collection__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <div class="ai-featured-collection__header-{{ ai_gen_id }}">
        <h2 class="ai-featured-collection__heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h2>
      </div>
    {% endif %}

    {% if block.settings.collection != blank %}
      <div class="ai-featured-collection__grid-{{ ai_gen_id }}">
        {% for product in block.settings.collection.products limit: block.settings.products_to_show %}
          <div class="ai-featured-collection__card-{{ ai_gen_id }}">
            <a
              href="{{ product.url }}"
              class="ai-featured-collection__card-inner-{{ ai_gen_id }}"
            >
              <div class="ai-featured-collection__image-wrapper-{{ ai_gen_id }}">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    class="ai-featured-collection__image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="600"
                    height="600"
                  >
                {% else %}
                  <div class="ai-featured-collection__image-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>

              <div class="ai-featured-collection__info-{{ ai_gen_id }}">
                <h3 class="ai-featured-collection__title-{{ ai_gen_id }}">
                  {{ product.title }}
                </h3>
                <div class="ai-featured-collection__price-{{ ai_gen_id }}">
                  {{ product.price | money_with_currency }}
                </div>
              </div>
            </a>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="ai-featured-collection__empty-state-{{ ai_gen_id }}">
        Select a collection to display products
      </div>
    {% endif %}
  </div>
</featured-collection-{{ ai_gen_id }}>

<script>
  (function() {
    class FeaturedCollection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-featured-collection__card-{{ ai_gen_id }}');
        this.setupHoverEffects();
      }

      setupHoverEffects() {
        this.cards.forEach((card) => {
          card.addEventListener('mousemove', (e) => {
            const rect = card.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            const centerX = rect.width / 2;
            const centerY = rect.height / 2;
            const rotateX = ((y - centerY) / centerY) * 10;
            const rotateY = ((x - centerX) / centerX) * 10;

            card.style.transform = `perspective(1000px) rotateX(${-rotateX}deg) rotateY(${rotateY}deg) scale(1.05)`;
          });

          card.addEventListener('mouseleave', () => {
            card.style.transform = '';
          });
        });
      }
    }

    customElements.define('featured-collection-{{ ai_gen_id }}', FeaturedCollection{{ ai_gen_id }});
  })();
</script>

