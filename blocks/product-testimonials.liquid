<div
  class="pdp-testimonials"
  style="{% render 'spacing-style', settings: block.settings %}"
  {{ block.shopify_attributes }}
>

  {%- for i in (1..6) -%}
    {%- assign name_key   = 'name_'   | append: i -%}
    {%- assign detail_key = 'detail_' | append: i -%}
    {%- assign photo_key  = 'photo_'  | append: i -%}
    {%- assign name_val   = block.settings[name_key] -%}
    {%- if name_val != blank or request.visual_preview_mode -%}

      <div class="pdp-tc">
        <div class="pdp-tc__avatar">
          {%- assign photo_val = block.settings[photo_key] -%}
          {%- if photo_val != blank -%}
            {{ photo_val | image_url: width: 160 | image_tag: width: 40, height: 40, loading: 'lazy', style: 'width:40px;height:40px;object-fit:cover;border-radius:50%;display:block;' }}
          {%- else -%}
            <span class="pdp-tc__initials">{{ name_val | slice: 0 | upcase }}</span>
          {%- endif -%}
        </div>
        <div class="pdp-tc__body">
          <div class="pdp-tc__top">
            <span class="pdp-tc__name">{{ name_val | default: 'Customer' }}</span>
            <span class="pdp-tc__stars" aria-label="5 stars">★★★★★</span>
          </div>
          {%- assign detail_val = block.settings[detail_key] -%}
          {%- if detail_val != blank -%}
            <p class="pdp-tc__detail">{{ detail_val }}</p>
          {%- endif -%}
        </div>
      </div>

    {%- endif -%}
  {%- endfor -%}

</div>

<style>
  .pdp-testimonials {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .pdp-tc {
    display: flex;
    align-items: center;
    gap: 10px;
    border: 1.5px solid rgba(0, 0, 0, 0.1);
    border-radius: 12px;
    padding: 10px 12px;
    background: #fff;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.07);
  }

  .pdp-tc__avatar {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    overflow: hidden;
    background: #e8e8e8;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pdp-tc__initials {
    font-size: 1rem;
    font-weight: 700;
    color: #666;
    line-height: 1;
  }

  .pdp-tc__body {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
    overflow: hidden;
  }

  .pdp-tc__top {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: nowrap;
    overflow: hidden;
  }

  .pdp-tc__name {
    font-size: 0.82rem;
    font-weight: 700;
    color: #111;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex-shrink: 1;
    min-width: 0;
  }

  .pdp-tc__stars {
    font-size: 0.72rem;
    color: #f59e0b;
    letter-spacing: 0.5px;
    line-height: 1;
    flex-shrink: 0;
  }

  .pdp-tc__detail {
    font-size: 0.75rem;
    color: #555;
    margin: 0;
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media screen and (max-width: 480px) {
    .pdp-testimonials {
      grid-template-columns: 1fr;
    }
  }
</style>

