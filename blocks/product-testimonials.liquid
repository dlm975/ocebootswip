<div
  class="pdp-testimonials"
  style="{% render 'spacing-style', settings: block.settings %}"
  {{ block.shopify_attributes }}
>

  <h3 class="pdp-testimonials__title">
    <span class="pdp-testimonials__title-star" aria-hidden="true">★</span>
    {{ block.settings.section_title }}
  </h3>

  {%- for i in (1..5) -%}
    {%- assign name_key   = 'name_'   | append: i -%}
    {%- assign detail_key = 'detail_' | append: i -%}
    {%- assign photo_key  = 'photo_'  | append: i -%}
    {%- assign t_name   = block.settings[name_key] -%}
    {%- assign t_detail = block.settings[detail_key] -%}
    {%- assign t_photo  = block.settings[photo_key] -%}

    {%- if t_name != blank or request.visual_preview_mode -%}
      <div class="pdp-testimonial-item">
        <span class="pdp-testimonial-item__avatar" aria-hidden="true">
          {%- if t_photo != blank -%}
            {{ t_photo | image_url: width: 80 | image_tag: width: 44, height: 44, style: 'width:44px;height:44px;object-fit:cover;border-radius:50%;display:block;' }}
          {%- else -%}
            <span class="pdp-testimonial-item__avatar-initials">
              {{- t_name | slice: 0 | upcase -}}
            </span>
          {%- endif -%}
        </span>
        <div class="pdp-testimonial-item__body">
          <div class="pdp-testimonial-item__top">
            <span class="pdp-testimonial-item__name">{{ t_name }}</span>
            <span class="pdp-testimonial-item__stars" aria-label="5 out of 5 stars">★★★★★</span>
          </div>
          {%- if t_detail != blank -%}
            <p class="pdp-testimonial-item__detail">{{ t_detail }}</p>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
  {%- endfor -%}

</div>

<style>
  .pdp-testimonials {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .pdp-testimonials__title {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 4px;
    color: #111;
  }

  .pdp-testimonials__title-star {
    font-size: 1.2rem;
    color: #f5a623;
    line-height: 1;
  }

  .pdp-testimonial-item {
    display: flex;
    align-items: center;
    gap: 14px;
    background: #f8f8f8;
    border-radius: 50px;
    padding: 10px 18px 10px 10px;
    box-sizing: border-box;
  }

  .pdp-testimonial-item__avatar {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    overflow: hidden;
    background: #ddd;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pdp-testimonial-item__avatar-initials {
    font-size: 1rem;
    font-weight: 700;
    color: #555;
    line-height: 1;
  }

  .pdp-testimonial-item__body {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .pdp-testimonial-item__top {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .pdp-testimonial-item__name {
    font-size: 0.85rem;
    font-weight: 700;
    color: #111;
    white-space: nowrap;
  }

  .pdp-testimonial-item__stars {
    font-size: 0.8rem;
    color: #22c55e;
    letter-spacing: 1px;
    line-height: 1;
  }

  .pdp-testimonial-item__detail {
    font-size: 0.75rem;
    color: #555;
    margin: 0;
    line-height: 1.3;
  }
</style>

