{% doc %}
  @prompt
    A Variant picker dropdown pill. If a Variant does not have multiple options, there should be no dropdown menu that opens out - just a starionary pill. The pills should be stacked side by side adapting text and pill size based on screen width. It is crucial that the text is centered in the pill. It is crucial that the text in the pill changes size to ensure the full string is visible regardless of character length. The dropdown arrow should sit in the center (top to bottom) of the pill. The pills should sit side by side horizontally., The variant label should size above the pill., The pills should fill the whole screen width, adapting based on string length.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-variant-picker-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-variant-picker__container-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.pill_gap }}px;
    align-items: flex-start;
    width: 100%;
  }

  .ai-variant-picker__option-{{ ai_gen_id }} {
    position: relative;
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.label_gap }}px;
  }

  .ai-variant-picker__label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_font_size }}px;
    color: {{ block.settings.label_color }};
    font-weight: {{ block.settings.label_font_weight }};
    text-align: center;
  }

  .ai-variant-picker__pill-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-variant-picker__select-{{ ai_gen_id }} {
    appearance: none;
    background-color: {{ block.settings.pill_background }};
    color: {{ block.settings.pill_text_color }};
    border: {{ block.settings.pill_border_width }}px solid {{ block.settings.pill_border_color }};
    border-radius: {{ block.settings.pill_border_radius }}px;
    padding: {{ block.settings.pill_padding_vertical }}px {{ block.settings.pill_padding_horizontal }}px;
    font-size: {{ block.settings.pill_font_size }}px;
    cursor: pointer;
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    width: 100%;
    transition: all 0.2s ease;
  }

  .ai-variant-picker__select-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.pill_hover_background }};
    border-color: {{ block.settings.pill_hover_border_color }};
  }

  .ai-variant-picker__select-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.pill_border_color }};
    outline-offset: 2px;
  }

  .ai-variant-picker__select-{{ ai_gen_id }}--has-dropdown {
    padding-right: calc({{ block.settings.pill_padding_horizontal }}px + 20px);
  }

  .ai-variant-picker__static-pill-{{ ai_gen_id }} {
    background-color: {{ block.settings.pill_background }};
    color: {{ block.settings.pill_text_color }};
    border: {{ block.settings.pill_border_width }}px solid {{ block.settings.pill_border_color }};
    border-radius: {{ block.settings.pill_border_radius }}px;
    padding: {{ block.settings.pill_padding_vertical }}px {{ block.settings.pill_padding_horizontal }}px;
    font-size: {{ block.settings.pill_font_size }}px;
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    width: 100%;
    display: block;
  }

  .ai-variant-picker__arrow-{{ ai_gen_id }} {
    position: absolute;
    right: {{ block.settings.pill_padding_horizontal }}px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    width: 12px;
    height: 12px;
    color: {{ block.settings.pill_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-variant-picker__label-{{ ai_gen_id }} {
      font-size: {{ block.settings.label_font_size_mobile }}px;
    }

    .ai-variant-picker__select-{{ ai_gen_id }},
    .ai-variant-picker__static-pill-{{ ai_gen_id }} {
      font-size: {{ block.settings.pill_font_size_mobile }}px;
      padding: {{ block.settings.pill_padding_vertical_mobile }}px {{ block.settings.pill_padding_horizontal_mobile }}px;
    }

    .ai-variant-picker__select-{{ ai_gen_id }}--has-dropdown {
      padding-right: calc({{ block.settings.pill_padding_horizontal_mobile }}px + 20px);
    }

    .ai-variant-picker__arrow-{{ ai_gen_id }} {
      right: {{ block.settings.pill_padding_horizontal_mobile }}px;
    }
  }
{% endstyle %}

<variant-picker-{{ ai_gen_id }}
  class="ai-variant-picker-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-variant-picker__container-{{ ai_gen_id }}">
    {% unless product.has_only_default_variant %}
      {% for option in product.options_with_values %}
        <div class="ai-variant-picker__option-{{ ai_gen_id }}">
          <div class="ai-variant-picker__label-{{ ai_gen_id }}">
            {{ option.name }}
          </div>
          <div class="ai-variant-picker__pill-wrapper-{{ ai_gen_id }}">
            {% if option.values.size > 1 %}
              <select
                class="ai-variant-picker__select-{{ ai_gen_id }} ai-variant-picker__select-{{ ai_gen_id }}--has-dropdown"
                name="options[{{ option.name | escape }}]"
                data-option-index="{{ forloop.index0 }}"
              >
                {% for value in option.values %}
                  <option
                    value="{{ value | escape }}"
                    {% if option.selected_value == value %}
                      selected
                    {% endif %}
                  >
                    {{ value }}
                  </option>
                {% endfor %}
              </select>
              <svg
                class="ai-variant-picker__arrow-{{ ai_gen_id }}"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            {% else %}
              <span class="ai-variant-picker__static-pill-{{ ai_gen_id }}">
                {{ option.values.first }}
              </span>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    {% endunless %}
  </div>
</variant-picker-{{ ai_gen_id }}>

<script>
  (function() {
    class VariantPicker{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.selects = this.querySelectorAll('.ai-variant-picker__select-{{ ai_gen_id }}');
      }

      connectedCallback() {
        this.selects.forEach((select) => {
          select.addEventListener('change', this.onVariantChange.bind(this));
        });
      }

      onVariantChange(event) {
        const selectedOptions = Array.from(this.selects).map((select) => select.value);
        
        const productForm = this.closest('form[action*="/cart/add"]');
        if (!productForm) return;

        const variantIdInput = productForm.querySelector('[name="id"]');
        if (!variantIdInput) return;

        const productData = JSON.parse(
          document.querySelector('[data-product-json]')?.textContent || '{}'
        );

        if (!productData.variants) return;

        const matchingVariant = productData.variants.find((variant) => {
          return variant.options.every((option, index) => {
            return option === selectedOptions[index];
          });
        });

        if (matchingVariant) {
          variantIdInput.value = matchingVariant.id;
          
          const changeEvent = new Event('change', { bubbles: true });
          variantIdInput.dispatchEvent(changeEvent);
        }
      }
    }

    customElements.define('variant-picker-{{ ai_gen_id }}', VariantPicker{{ ai_gen_id }});
  })();
</script>

