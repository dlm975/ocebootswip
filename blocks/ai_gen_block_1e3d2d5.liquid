          width="24"
          height="24"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div class="ai-sticky-nav-size-grid-{{ ai_gen_id }}">
      {% for i in (1..12) %}
        {% assign size_key = 'eu_size_' | append: i %}
        {% assign collection_key = 'eu_collection_' | append: i %}
        {% if block.settings[size_key] != blank and block.settings[collection_key] != blank %}
          <a
            href="{{ block.settings[collection_key].url }}"
            class="ai-sticky-nav-size-link-{{ ai_gen_id }}"
          >
            {{ block.settings[size_key] }}
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</sticky-nav-{{ ai_gen_id }}>

<script>
  (function() {
    class StickyNav{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.mainButton = this.querySelector('[data-main-button]');
        this.mainText = this.querySelector('.ai-sticky-nav-main-text-{{ ai_gen_id }}');
        this.icon = this.querySelector('[data-icon]');
        this.sizeTypesContainer = this.querySelector('[data-size-types]');
        this.sizeTypeButtons = this.querySelectorAll('[data-size-type]');
        this.sizeLists = {
          us: this.querySelector('[data-size-list-us]'),
          uk: this.querySelector('[data-size-list-uk]'),
          eu: this.querySelector('[data-size-list-eu]')
        };
        this.closeButtons = this.querySelectorAll('[data-close-list]');
        this.currentState = 'main';
      }

      connectedCallback() {
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.mainButton.addEventListener('click', () => this.toggleSizeTypes());

        this.sizeTypeButtons.forEach(button => {
          button.addEventListener('click', (e) => {
            const sizeType = e.currentTarget.getAttribute('data-size-type');
            this.showSizeList(sizeType);
          });
        });

        this.closeButtons.forEach(button => {
          button.addEventListener('click', () => this.closeSizeList());
        });

        document.addEventListener('click', (e) => {
          if (!this.contains(e.target)) {
            this.resetToMain();
          }
        });
      }

      toggleSizeTypes() {
        if (this.currentState === 'main') {
          this.mainText.style.display = 'none';
          this.sizeTypesContainer.classList.add('active');
          this.icon.classList.add('rotated');
          this.mainButton.setAttribute('aria-expanded', 'true');
          this.currentState = 'sizeTypes';
        } else {
          this.resetToMain();
        }
      }

      showSizeList(sizeType) {
        Object.values(this.sizeLists).forEach(list => {
          list.classList.remove('active');
        });

        if (this.sizeLists[sizeType]) {
          this.sizeLists[sizeType].classList.add('active');
          this.currentState = 'sizeList';
        }
      }

      closeSizeList() {
        Object.values(this.sizeLists).forEach(list => {
          list.classList.remove('active');
        });
        this.currentState = 'sizeTypes';
      }

      resetToMain() {
        this.mainText.style.display = '';
        this.sizeTypesContainer.classList.remove('active');
        this.icon.classList.remove('rotated');
        this.mainButton.setAttribute('aria-expanded', 'false');
        Object.values(this.sizeLists).forEach(list => {
          list.classList.remove('active');
        });
        this.currentState = 'main';
      }
    }

    customElements.define('sticky-nav-{{ ai_gen_id }}', StickyNav{{ ai_gen_id }});
  })();
</script>

