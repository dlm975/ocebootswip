{% doc %}
  @prompt
    BEFORE YOU EVEN START: as this is a navigation bar, it MUST constantly sit above all other sections in the theme so it is visible at all times. - Create a sticky navigation bar that stays fixed at the bottom of the page at all times. The bar should be a long horizontal rectangle with heavily rounded edges (large border radius). Add a prominent shadow effect to create a 3D appearance that makes it appear to float above the page. The navigation bar should contain customizable menu links and remain visible even when scrolling. Use a glass like texture for the background . Create an opacity slider for this. Ideally the content in the bar will be "Shop By Size" that when clicked, the bar will then present with 3 options: US Size, UK Size, EU Size. When the size type options is clicked, a list will expanded onto the screen with the range of size options, each linked to a collection in my store, Make sure that behaviourally it is "at FRONT" at all times, with no other elements hovering above. Provide ability to change main button text and size type label font. Also make the "Shop By Size" text disappear on the size type label screen.
    
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-sticky-nav-{{ ai_gen_id }} {
    position: fixed;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 9999;
    width: 90%;
    max-width: {{ block.settings.max_width }}px;
    display: block;
  }

  .ai-sticky-nav-container-{{ ai_gen_id }} {
    background: {{ block.settings.background_color }};
    backdrop-filter: blur({{ block.settings.blur_amount }}px);
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    box-shadow: 0 {{ block.settings.shadow_offset_y }}px {{ block.settings.shadow_blur }}px {{ block.settings.shadow_spread }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity | divided_by: 100.0 }});
    opacity: {{ block.settings.bar_opacity | divided_by: 100.0 }};
    transition: all 0.3s ease;
  }

  .ai-sticky-nav-main-button-{{ ai_gen_id }} {
    width: 100%;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    color: {{ block.settings.text_color }};
    font-family: {{ block.settings.main_button_font.family }}, {{ block.settings.main_button_font.fallback_families }};
    font-weight: {{ block.settings.main_button_font.weight }};
    font-size: {{ block.settings.main_button_font_size }}px;
  }

  .ai-sticky-nav-main-button-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .ai-sticky-nav-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    transition: transform 0.3s ease;
  }

  .ai-sticky-nav-icon-{{ ai_gen_id }}.rotated {
    transform: rotate(180deg);
  }

  .ai-sticky-nav-size-types-{{ ai_gen_id }} {
    display: none;
    gap: 12px;
    justify-content: center;
    align-items: center;
  }

  .ai-sticky-nav-size-types-{{ ai_gen_id }}.active {
    display: flex;
  }

  .ai-sticky-nav-size-type-button-{{ ai_gen_id }} {
    background: none;
    border: 2px solid {{ block.settings.text_color }};
    border-radius: {{ block.settings.size_button_radius }}px;
    padding: 10px 20px;
    cursor: pointer;
    color: {{ block.settings.text_color }};
    font-family: {{ block.settings.size_type_font.family }}, {{ block.settings.size_type_font.fallback_families }};
    font-weight: {{ block.settings.size_type_font.weight }};
    font-size: {{ block.settings.size_type_font_size }}px;
    transition: all 0.3s ease;
  }

  .ai-sticky-nav-size-type-button-{{ ai_gen_id }}:hover {
    background: {{ block.settings.text_color }};
    color: {{ block.settings.background_color }};
  }

  .ai-sticky-nav-size-list-{{ ai_gen_id }} {
    position: fixed;
    bottom: calc(20px + {{ block.settings.padding_vertical | times: 2 | plus: 60 }}px);
    left: 50%;
    transform: translateX(-50%);
    width: 90%;
    max-width: {{ block.settings.max_width }}px;
    background: {{ block.settings.background_color }};
    backdrop-filter: blur({{ block.settings.blur_amount }}px);
    border-radius: {{ block.settings.border_radius }}px;
    padding: 20px;
    box-shadow: 0 {{ block.settings.shadow_offset_y }}px {{ block.settings.shadow_blur }}px {{ block.settings.shadow_spread }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity | divided_by: 100.0 }});
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
    z-index: 9998;
    max-height: 60vh;
    overflow-y: auto;
  }

  .ai-sticky-nav-size-list-{{ ai_gen_id }}.active {
    opacity: {{ block.settings.bar_opacity | divided_by: 100.0 }};
    visibility: visible;
  }

  .ai-sticky-nav-size-list-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid {{ block.settings.text_color }};
  }

  .ai-sticky-nav-size-list-title-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-family: {{ block.settings.size_type_font.family }}, {{ block.settings.size_type_font.fallback_families }};
    font-weight: {{ block.settings.size_type_font.weight }};
    font-size: {{ block.settings.size_type_font_size }}px;
    margin: 0;
  }

  .ai-sticky-nav-close-button-{{ ai_gen_id }} {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: {{ block.settings.text_color }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-sticky-nav-close-button-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-sticky-nav-size-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
    gap: 12px;
  }

  .ai-sticky-nav-size-link-{{ ai_gen_id }} {
    display: block;
    text-align: center;
    padding: 12px;
    background: none;
    border: 2px solid {{ block.settings.text_color }};
    border-radius: {{ block.settings.size_button_radius }}px;
    color: {{ block.settings.text_color }};
    text-decoration: none;
    font-family: {{ block.settings.size_type_font.family }}, {{ block.settings.size_type_font.fallback_families }};
    font-weight: {{ block.settings.size_type_font.weight }};
    font-size: {{ block.settings.size_type_font_size }}px;
    transition: all 0.3s ease;
  }

  .ai-sticky-nav-size-link-{{ ai_gen_id }}:hover {
    background: {{ block.settings.text_color }};
    color: {{ block.settings.background_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-sticky-nav-{{ ai_gen_id }} {
      width: 95%;
    }

    .ai-sticky-nav-size-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(auto-fill, minmax(60px, 1fr));
      gap: 8px;
    }

    .ai-sticky-nav-size-link-{{ ai_gen_id }} {
      padding: 10px 8px;
      font-size: {{ block.settings.size_type_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<sticky-nav-{{ ai_gen_id }} class="ai-sticky-nav-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-sticky-nav-container-{{ ai_gen_id }}">
    <button
      class="ai-sticky-nav-main-button-{{ ai_gen_id }}"
      data-main-button
      aria-label="{{ block.settings.main_button_text }}"
      aria-expanded="false"
    >
      <span class="ai-sticky-nav-main-text-{{ ai_gen_id }}">{{ block.settings.main_button_text }}</span>
      <svg
        class="ai-sticky-nav-icon-{{ ai_gen_id }}"
        data-icon
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </button>

    <div class="ai-sticky-nav-size-types-{{ ai_gen_id }}" data-size-types>
      <button
        class="ai-sticky-nav-size-type-button-{{ ai_gen_id }}"
        data-size-type="us"
      >
        {{ block.settings.us_size_label }}
      </button>
      <button
        class="ai-sticky-nav-size-type-button-{{ ai_gen_id }}"
        data-size-type="uk"
      >
        {{ block.settings.uk_size_label }}
      </button>
      <button
        class="ai-sticky-nav-size-type-button-{{ ai_gen_id }}"
        data-size-type="eu"
      >
        {{ block.settings.eu_size_label }}
      </button>
    </div>
  </div>

  <div class="ai-sticky-nav-size-list-{{ ai_gen_id }}" data-size-list-us>
    <div class="ai-sticky-nav-size-list-header-{{ ai_gen_id }}">
      <h3 class="ai-sticky-nav-size-list-title-{{ ai_gen_id }}">{{ block.settings.us_size_label }}</h3>
      <button class="ai-sticky-nav-close-button-{{ ai_gen_id }}" data-close-list aria-label="Close">
        <svg
          width="24"
          height="24"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div class="ai-sticky-nav-size-grid-{{ ai_gen_id }}">
      {% for i in (1..12) %}
        {% assign size_key = 'us_size_' | append: i %}
        {% assign collection_key = 'us_collection_' | append: i %}
        {% if block.settings[size_key] != blank and block.settings[collection_key] != blank %}
          <a
            href="{{ block.settings[collection_key].url }}"
            class="ai-sticky-nav-size-link-{{ ai_gen_id }}"
          >
            {{ block.settings[size_key] }}
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="ai-sticky-nav-size-list-{{ ai_gen_id }}" data-size-list-uk>
    <div class="ai-sticky-nav-size-list-header-{{ ai_gen_id }}">
      <h3 class="ai-sticky-nav-size-list-title-{{ ai_gen_id }}">{{ block.settings.uk_size_label }}</h3>
      <button class="ai-sticky-nav-close-button-{{ ai_gen_id }}" data-close-list aria-label="Close">
        <svg
          width="24"
          height="24"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div class="ai-sticky-nav-size-grid-{{ ai_gen_id }}">
      {% for i in (1..12) %}
        {% assign size_key = 'uk_size_' | append: i %}
        {% assign collection_key = 'uk_collection_' | append: i %}
        {% if block.settings[size_key] != blank and block.settings[collection_key] != blank %}
          <a
            href="{{ block.settings[collection_key].url }}"
            class="ai-sticky-nav-size-link-{{ ai_gen_id }}"
          >
            {{ block.settings[size_key] }}
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="ai-sticky-nav-size-list-{{ ai_gen_id }}" data-size-list-eu>
    <div class="ai-sticky-nav-size-list-header-{{ ai_gen_id }}">
      <h3 class="ai-sticky-nav-size-list-title-{{ ai_gen_id }}">{{ block.settings.eu_size_label }}</h3>
      <button class="ai-sticky-nav-close-button-{{ ai_gen_id }}" data-close-list aria-label="Close">
