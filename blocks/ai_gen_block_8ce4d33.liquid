{% doc %}
  @prompt
    a testimonial section. 3 rows of testimonial cards. the cards are long rounded rectangle capsules with a circular pic, name and description. that should slide horizontally across the screen as the user scrolls to give an interactive feeling. each testimonial will be editable,  the padding between rows should be small. there should be 5 cards of testimonials per row. these rows should slide as the user scrolls down the screen, not automatically., the first row should begin with testimonial 2 in the center of screen. the second row should begin with testimonial 4 in the center of screen. the first row should begin with testimonial 2 in the center of screen. ensure that the block width is capped to the stated shopify sstandard dimensions of desktop and mobile view to ensure that there is absolutely no horizontal scrollability., the middle/ second row should begin with testimonial 4 in the center of screen., the scroll/slide should not begin until the first row is in view. , the second row should begin with testimonial 10 in the center of screen.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonials-container-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    overflow: hidden;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-testimonials-rows-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.row_gap }}px;
    max-width: 100vw;
  }

  .ai-testimonials-row-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    will-change: transform;
  }

  .ai-testimonial-card-{{ ai_gen_id }} {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 16px;
    padding: {{ block.settings.card_padding }}px;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    min-width: {{ block.settings.card_min_width }}px;
    max-width: {{ block.settings.card_max_width }}px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-testimonial-image-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.image_size }}px;
    height: {{ block.settings.image_size }}px;
    border-radius: 50%;
    overflow: hidden;
    background-color: #f0f0f0;
  }

  .ai-testimonial-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-testimonial-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #e0e0e0;
  }

  .ai-testimonial-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.5;
  }

  .ai-testimonial-content-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
  }

  .ai-testimonial-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.name_font_size }}px;
    font-weight: 600;
    color: {{ block.settings.name_color }};
    margin: 0 0 8px;
  }

  .ai-testimonial-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_font_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.5;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-testimonial-card-{{ ai_gen_id }} {
      min-width: {{ block.settings.card_min_width | times: 0.8 }}px;
      max-width: {{ block.settings.card_max_width | times: 0.8 }}px;
      padding: {{ block.settings.card_padding | times: 0.8 }}px;
    }

    .ai-testimonial-image-{{ ai_gen_id }} {
      width: {{ block.settings.image_size | times: 0.8 }}px;
      height: {{ block.settings.image_size | times: 0.8 }}px;
    }

    .ai-testimonial-name-{{ ai_gen_id }} {
      font-size: {{ block.settings.name_font_size | times: 0.9 }}px;
    }

    .ai-testimonial-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<testimonials-slider-{{ ai_gen_id }}
  class="ai-testimonials-container-{{ ai_gen_id }}"
  data-scroll-speed="{{ block.settings.scroll_speed }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-testimonials-rows-{{ ai_gen_id }}">
    {% for row_num in (1..3) %}
      {% assign row_offset_key = 'row_' | append: row_num | append: '_offset' %}
      {% assign row_offset = block.settings[row_offset_key] %}
      
      <div 
        class="ai-testimonials-row-{{ ai_gen_id }}" 
        data-row="{{ row_num }}"
        data-offset="{{ row_offset }}"
      >
        {% for i in (1..5) %}
          {% assign testimonial_num = row_num | minus: 1 | times: 5 | plus: i %}
          {% assign name_key = 'testimonial_' | append: testimonial_num | append: '_name' %}
          {% assign text_key = 'testimonial_' | append: testimonial_num | append: '_text' %}
          {% assign image_key = 'testimonial_' | append: testimonial_num | append: '_image' %}
          
          {% assign name = block.settings[name_key] %}
          {% assign text = block.settings[text_key] %}
          {% assign image = block.settings[image_key] %}
          
          <div class="ai-testimonial-card-{{ ai_gen_id }}">
            <div class="ai-testimonial-image-{{ ai_gen_id }}">
              {% if image %}
                <img
                  src="{{ image | image_url: width: 200 }}"
                  alt="{{ name | escape }}"
                  loading="lazy"
                  width="200"
                  height="200"
                >
              {% else %}
                <div class="ai-testimonial-image-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            <div class="ai-testimonial-content-{{ ai_gen_id }}">
              {% if name != blank %}
                <h3 class="ai-testimonial-name-{{ ai_gen_id }}">{{ name }}</h3>
              {% else %}
                <h3 class="ai-testimonial-name-{{ ai_gen_id }}">Customer {{ testimonial_num }}</h3>
              {% endif %}
              {% if text != blank %}
                <p class="ai-testimonial-text-{{ ai_gen_id }}">{{ text }}</p>
              {% else %}
                <p class="ai-testimonial-text-{{ ai_gen_id }}">Add a testimonial description here.</p>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endfor %}
  </div>
</testimonials-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class TestimonialsSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.rows = [];
        this.scrollSpeed = parseFloat(this.dataset.scrollSpeed) || 0.5;
        this.lastScrollY = window.scrollY;
        this.isInView = false;
        this.hasStarted = false;
      }

      connectedCallback() {
        this.rows = Array.from(this.querySelectorAll('.ai-testimonials-row-{{ ai_gen_id }}'));
        this.initializeRows();
        this.setupIntersectionObserver();
        this.setupScrollListener();
      }

      initializeRows() {
        this.rows.forEach((row, index) => {
          const offset = parseInt(row.dataset.offset) || 0;
          const cards = Array.from(row.children);
          const cardWidth = cards[0]?.offsetWidth || 0;
          const gap = {{ block.settings.card_gap }};
          const totalCardWidth = cardWidth + gap;
          
          const initialOffset = -offset * totalCardWidth;
          row.style.transform = `translateX(${initialOffset}px)`;
          row.dataset.currentOffset = initialOffset;
          
          cards.forEach(card => {
            const clone = card.cloneNode(true);
            row.appendChild(clone);
          });
        });
      }

      setupIntersectionObserver() {
        const options = {
          root: null,
          rootMargin: '0px',
          threshold: 0.1
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              this.isInView = true;
              if (!this.hasStarted) {
                this.hasStarted = true;
                this.lastScrollY = window.scrollY;
              }
            } else {
              this.isInView = false;
            }
          });
        }, options);

        observer.observe(this);
      }

      setupScrollListener() {
        let ticking = false;

        window.addEventListener('scroll', () => {
          if (!ticking) {
            window.requestAnimationFrame(() => {
              this.handleScroll();
              ticking = false;
            });
            ticking = true;
          }
        });
      }

      handleScroll() {
        if (!this.isInView || !this.hasStarted) {
          return;
        }

        const currentScrollY = window.scrollY;
        const scrollDelta = currentScrollY - this.lastScrollY;
        this.lastScrollY = currentScrollY;

        this.rows.forEach((row, index) => {
          const cards = Array.from(row.children);
          const cardWidth = cards[0]?.offsetWidth || 0;
          const gap = {{ block.settings.card_gap }};
          const totalCardWidth = cardWidth + gap;
          const totalWidth = totalCardWidth * (cards.length / 2);

          let currentOffset = parseFloat(row.dataset.currentOffset) || 0;
          
          const direction = index % 2 === 0 ? -1 : 1;
          currentOffset += scrollDelta * this.scrollSpeed * direction;

          if (direction === -1) {
            if (currentOffset <= -totalWidth) {
              currentOffset += totalWidth;
            } else if (currentOffset > 0) {
              currentOffset -= totalWidth;
            }
          } else {
            if (currentOffset >= totalWidth) {
              currentOffset -= totalWidth;
            } else if (currentOffset < 0) {
              currentOffset += totalWidth;
            }
          }

          row.style.transform = `translateX(${currentOffset}px)`;
          row.dataset.currentOffset = currentOffset;
        });
      }
    }

    customElements.define('testimonials-slider-{{ ai_gen_id }}', TestimonialsSlider{{ ai_gen_id }});
  })();
</script>

